.compliance {
  margin-top: 34rpx;
  padding: 24rpx;
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  border: 1rpx solid rgba(201, 157, 76, 0.25);
  border-radius: 18rpx;
  color: rgba(247, 239, 223, 0.58);
  background: rgba(255, 255, 255, 0.035);
  font-size: 22rpx;
  line-height: 1.62;
}

.compliance.compact {
  margin-top: 24rpx;
  padding: 20rpx;
}

.seal {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  display: grid;
  place-items: center;
  border-radius: 12rpx;
  color: #f1d27d;
  border: 1rpx solid rgba(201, 157, 76, 0.36);
  background: rgba(201, 157, 76, 0.1);
  font-family: "Source Han Serif SC", "Noto Serif CJK SC", "Songti SC", "STSong", serif;
  font-weight: 700;
}
