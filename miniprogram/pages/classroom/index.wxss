.classroom-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: calc(48rpx + env(safe-area-inset-top)) 48rpx calc(220rpx + env(safe-area-inset-bottom));
  color: #f7efdf;
  background:
    radial-gradient(circle at 72% 8%, rgba(216, 183, 111, 0.12), transparent 28%),
    linear-gradient(180deg, #0a100f 0%, #070d0b 48%, #030605 100%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", "Microsoft YaHei", sans-serif;
}

.classroom-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.mist {
  opacity: 0.62;
  background:
    radial-gradient(ellipse at 46% 16%, rgba(255, 246, 226, 0.055), transparent 42%),
    linear-gradient(110deg, transparent 16%, rgba(255, 255, 255, 0.024) 44%, transparent 76%);
}

.grain {
  opacity: 0.08;
  background:
    linear-gradient(90deg, rgba(241, 210, 125, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(241, 210, 125, 0.035) 1rpx, transparent 1rpx);
  background-size: 92rpx 92rpx;
}

.classroom-content {
  position: relative;
  z-index: 2;
}

.head {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.seal {
  width: 82rpx;
  height: 82rpx;
  display: grid;
  place-items: center;
  border-radius: 24rpx;
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.36);
  background: rgba(255, 255, 255, 0.045);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 900;
}

.head text {
  color: #fff7e7;
  font-size: 30rpx;
  font-weight: 900;
}

.head view view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.46);
  font-size: 22rpx;
}

.hero-card,
.lesson-card,
.classroom-compliance {
  position: relative;
  margin-top: 30rpx;
  padding: 30rpx;
  overflow: hidden;
  border-radius: 30rpx;
  border: 1rpx solid rgba(241, 210, 125, 0.14);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.052), rgba(255, 255, 255, 0.016)),
    rgba(8, 13, 12, 0.52);
}

.hero-card text {
  display: block;
  color: #f6d886;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.hero-card view {
  margin-top: 14rpx;
  color: #fff7e7;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 40rpx;
  line-height: 1.45;
  font-weight: 900;
}

.content-list {
  margin-top: 24rpx;
  display: grid;
  gap: 18rpx;
}

.lesson-card {
  margin-top: 0;
}

.lesson-type {
  width: 84rpx;
  height: 44rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: #11140f;
  background: linear-gradient(180deg, #f1d27d, #c99d4c);
  font-size: 22rpx;
  font-weight: 900;
}

.lesson-main {
  margin-top: 18rpx;
}

.lesson-main text {
  color: #fff7e7;
  font-size: 30rpx;
  font-weight: 900;
}

.lesson-main view {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.58);
  font-size: 24rpx;
  line-height: 1.55;
}

.lesson-foot {
  margin-top: 22rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
}

.lesson-foot text {
  color: rgba(241, 210, 125, 0.68);
  font-size: 22rpx;
  font-weight: 900;
}

.lesson-foot button,
.home-link,
.lesson-share {
  min-height: 70rpx;
  padding: 0 24rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: rgba(247, 239, 223, 0.82);
  border: 1rpx solid rgba(241, 210, 125, 0.22);
  background: rgba(201, 157, 76, 0.08);
  font-size: 24rpx;
  font-weight: 900;
}

.lesson-share {
  width: 100%;
  min-height: 62rpx;
  margin-top: 18rpx;
  color: rgba(241, 210, 125, 0.78);
  background: rgba(255, 255, 255, 0.035);
}

.classroom-compliance {
  color: rgba(247, 239, 223, 0.56);
  font-size: 24rpx;
  line-height: 1.58;
}

.home-link {
  width: 100%;
  margin-top: 24rpx;
  color: #11140f;
  background: linear-gradient(105deg, rgba(255, 245, 205, 0.96), rgba(227, 181, 82, 0.96));
}
