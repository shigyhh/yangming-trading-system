.current-card {
  margin-top: 34rpx;
  padding: 34rpx 30rpx;
}

.current-card > view,
.current-card > button,
.stage-card > view,
.axis-card > text,
.axis-flow,
.goal-card > text,
.goal-card > view {
  position: relative;
  z-index: 1;
}

.axis-card {
  margin-top: 34rpx;
  padding: 30rpx 26rpx;
}

.axis-card > text {
  display: block;
  color: #b49355;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.axis-flow {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.axis-flow > view {
  min-height: 126rpx;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.045);
}

.axis-flow text {
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 28rpx;
  font-weight: 500;
}

.axis-flow view view {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.54);
  font-size: 22rpx;
  line-height: 1.42;
}

.stage-no {
  color: #b49355;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.current-title {
  margin-top: 16rpx;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 52rpx;
  font-weight: 500;
}

.current-subtitle {
  margin-top: 14rpx;
  color: rgba(247, 239, 223, 0.64);
  font-size: 27rpx;
  line-height: 1.64;
}

.current-core {
  margin-top: 12rpx;
  color: #f1d27d;
  font-size: 25rpx;
  font-weight: 900;
}

.current-meta {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.current-meta > view {
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.045);
}

.current-meta text {
  color: #f1d27d;
  font-family: "ZX-Harmony", "HarmonyOS Sans SC", "HarmonyOS Sans", -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
  font-size: 40rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.current-meta view view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.5);
  font-size: 22rpx;
}

.stage-bar {
  height: 10rpx;
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.stage-bar view {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, rgba(85, 174, 158, 0.86), rgba(241, 210, 125, 0.96));
}

.commandment {
  margin: 28rpx 0;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.07);
}

.commandment text,
.goal-card text {
  display: block;
  color: #b49355;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.commandment view,
.goal-card view {
  margin: 10rpx 0 22rpx;
  color: rgba(247, 239, 223, 0.84);
  font-size: 28rpx;
  line-height: 1.62;
  text-align: left;
}

.training-tags,
.stage-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.training-tags text,
.stage-tags text {
  min-height: 44rpx;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  color: #f6e0aa;
  border: 1rpx solid rgba(201, 157, 76, 0.28);
  background: rgba(201, 157, 76, 0.08);
  font-family: "ZX-Harmony", "HarmonyOS Sans SC", "HarmonyOS Sans", sans-serif;
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.stage-list {
  display: grid;
  gap: 20rpx;
}

.training-seven-list {
  display: grid;
  gap: 20rpx;
}

.training-seven-card {
  width: 100%;
  min-height: 226rpx;
  padding: 28rpx;
  display: block;
  text-align: left;
  border-radius: 28rpx;
}

.training-seven-card.active {
  border-color: rgba(241, 210, 125, 0.3);
  background: rgba(201, 157, 76, 0.08);
}

.training-seven-top,
.training-seven-day,
.training-seven-main,
.training-seven-foot,
.retest-stage-card > view,
.retest-stage-card > text {
  position: relative;
  z-index: 1;
}

.training-seven-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.training-seven-day {
  min-height: 48rpx;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  border: 1rpx solid rgba(241, 210, 125, 0.18);
  background: rgba(241, 210, 125, 0.055);
  color: #b49355;
  font-size: 24rpx;
  font-weight: 900;
}

.training-seven-top > text {
  flex: 0 0 auto;
  color: rgba(247, 239, 223, 0.48);
  font-size: 24rpx;
  font-weight: 900;
}

.training-seven-main text {
  display: block;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.24;
}

.training-seven-main view {
  margin-top: 18rpx;
  color: rgba(247, 239, 223, 0.64);
  font-size: 28rpx;
  line-height: 1.62;
}

.training-seven-foot {
  margin-top: 24rpx;
  color: rgba(241, 210, 125, 0.78);
  font-size: 25rpx;
  font-weight: 900;
}

.training-seven-card.done .training-seven-top > text {
  color: #58c2ad;
}

.retest-stage-card {
  margin-top: 22rpx;
  padding: 26rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.retest-stage-card view text {
  display: block;
  color: #f1d27d;
  font-size: 25rpx;
  font-weight: 900;
}

.retest-stage-card view view {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.58);
  font-size: 24rpx;
  line-height: 1.5;
}

.retest-stage-card > text {
  flex: 0 0 auto;
  color: #11140f;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f1d27d, #bd8841);
  font-size: 22rpx;
  font-weight: 900;
}

.stage-card {
  width: 100%;
  min-height: 166rpx;
  padding: 26rpx 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  text-align: left;
}

.stage-card.locked {
  opacity: 0.48;
}

.stage-index {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  display: grid;
  place-items: center;
  border-radius: 22rpx;
  color: #11140f;
  background: linear-gradient(180deg, #f1d27d, #bd8841);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 32rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
  box-shadow: 0 12rpx 26rpx rgba(201, 157, 76, 0.16);
}

.stage-card.locked .stage-index {
  color: rgba(247, 239, 223, 0.52);
  background: rgba(255, 255, 255, 0.08);
}

.stage-main {
  min-width: 0;
  flex: 1;
}

.stage-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.stage-head text:first-child {
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 30rpx;
  font-weight: 500;
}

.stage-head text:last-child {
  color: #f1d27d;
  font-size: 22rpx;
  font-weight: 900;
}

.stage-copy,
.stage-progress,
.stage-core,
.stage-evidence {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.54);
  font-size: 24rpx;
  line-height: 1.48;
}

.stage-core {
  color: #f1d27d;
  font-weight: 900;
}

.stage-evidence {
  color: rgba(247, 239, 223, 0.42);
  font-size: 22rpx;
}

.stage-evidence text {
  margin-right: 12rpx;
}

.stage-evidence text:first-child {
  color: #b49355;
  font-weight: 900;
}

.stage-rule {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(201, 157, 76, 0.12);
  background: rgba(201, 157, 76, 0.05);
}

.stage-rule text {
  display: block;
  color: #b49355;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.stage-rule view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.62);
  font-size: 23rpx;
  line-height: 1.48;
}

.stage-tags {
  margin-top: 16rpx;
}

.stage-bar.small {
  height: 8rpx;
  margin-top: 18rpx;
}

.goal-card {
  margin-top: 26rpx;
  padding: 30rpx 28rpx 14rpx;
}
