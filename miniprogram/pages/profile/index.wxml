<view class="page-shell">
  <view class="page-content">
    <text class="eyebrow">PROFILE · 我的心镜</text>

    <view class="profile-card card">
      <view class="avatar">心</view>
      <view class="profile-main">
        <view>{{profile.nickname || '修行者'}}</view>
        <text>{{profile.growth_level || profile.stage || '立志'}} · {{result ? result.primary : '未照见'}}</text>
      </view>
    </view>

    <view class="profile-stats card">
      <view>
        <text>{{profile.points || 0}}</text>
        <view>知行积分</view>
      </view>
      <view>
        <text>{{continuity.currentStreak}}</text>
        <view>连续打卡</view>
      </view>
      <view>
        <text>{{reviewSaved ? '已省' : '待省'}}</text>
        <view>今日省察</view>
      </view>
    </view>

    <view class="evidence-account-card card">
      <view class="card-album-head">
        <view>
          <text>{{closureEvidenceChain.title}}</text>
          <view>{{closureEvidenceChain.subtitle}}</view>
        </view>
        <text>{{closureEvidenceChain.progressText}}</text>
      </view>
      <view class="journey-progress-grid">
        <view>
          <text>今日训练</text>
          <view>{{unifiedJourneyView.dailyPracticeDay}}</view>
        </view>
        <view>
          <text>全年修行</text>
          <view>{{unifiedJourneyView.annualPracticeDay}}</view>
        </view>
        <view>
          <text>七日复测</text>
          <view>{{unifiedJourneyView.sevenDayProgress}}</view>
        </view>
        <view>
          <text>今日三印</text>
          <view>{{unifiedJourneyView.todaySealProgress}}</view>
        </view>
      </view>
      <view class="closure-chain-list">
        <view
          wx:for="{{closureEvidenceChain.steps}}"
          wx:key="key"
          class="{{item.done ? 'done' : item.current ? 'current' : ''}}"
        >
          <text>{{item.numberText}}</text>
          <view>
            <text>{{item.title}}</text>
            <view>{{item.detail}}</view>
          </view>
          <text>{{item.statusText}}</text>
        </view>
      </view>
      <view class="closure-next-action">下一步：{{closureEvidenceChain.nextActionText}}</view>
    </view>

    <view class="identity-card card">
      <view class="identity-head">
        <view>
          <text>手机号贯穿档案</text>
          <view>{{userBinding.phoneBound ? userBinding.phoneMask : '绑定后贯穿报告、训练、复测、邀约与助教承接'}}</view>
        </view>
        <text>{{userBinding.phoneBound ? '已绑定' : '待绑定'}}</text>
      </view>
      <view class="identity-chain">
        <view>网站测评报告</view>
        <view>小程序训练记录</view>
        <view>复测变化</view>
        <view>邀请码来源</view>
        <view>助教承接摘要</view>
      </view>
      <view class="identity-input">
        <input type="number" maxlength="11" value="{{phoneDraft}}" bindinput="inputPhone" placeholder="输入手机号完成贯穿绑定" />
        <button bindtap="savePhoneBinding">{{userBinding.phoneBound ? '更新绑定' : '绑定'}}</button>
      </view>
      <view class="identity-source">邀请码来源：{{userBinding.inviteSource || '自然进入'}}</view>
      <view class="identity-source">我的同修码：{{userBinding.inviteCode || localUserProfile.inviteCode || '待生成'}}</view>
      <view class="identity-source">统一档案ID：{{userBinding.userIdDisplay || '待生成'}}</view>
    </view>

    <view class="sync-bridge-card card">
      <view class="sync-bridge-head">
        <view>
          <text>高频陪跑端</text>
          <view>不是展示端，是每日修行、交易复盘与活镜成长的陪跑端</view>
        </view>
        <button bindtap="generateInviteCard">邀同修照见</button>
      </view>
      <view class="sync-bridge-grid">
        <view wx:for="{{userDataChain}}" wx:key="*this">{{item}}</view>
      </view>
      <view wx:if="{{debugMode}}" class="debug-grid">
        <view wx:for="{{debugDataChain}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="assistant-summary">{{localUserProfile.assistantSummary}}</view>
    </view>

    <view class="handoff-card card">
      <view class="handoff-head">
        <view>
          <text>助教承接</text>
          <view>{{livingMirrorStats.totalReviews || 0}} 条真实复盘 · {{assistantHandoff.currentMirror || '待照见'}}</view>
        </view>
        <text>{{assistantHandoff.statusText || (userBinding.phoneBound ? '可承接' : '待绑定')}}</text>
      </view>
      <view class="handoff-triggers">
        <view wx:for="{{assistantHandoff.triggers}}" wx:key="key" class="{{item.done ? 'done' : ''}}">
          <text>{{item.done ? '已成' : '待成'}}</text>
          <view>{{item.label}}</view>
        </view>
      </view>
      <view class="handoff-grid">
        <view>
          <text>当前主镜</text>
          <view>{{assistantHandoff.currentMirror || '待照见'}}</view>
        </view>
        <view>
          <text>高频心贼</text>
          <view>{{assistantHandoff.highFrequencyThieves || '待照见'}}</view>
        </view>
        <view>
          <text>最近念头</text>
          <view>{{assistantHandoff.recentThought || '待记录'}}</view>
        </view>
        <view>
          <text>训练营建议</text>
          <view>{{assistantHandoff.campSuggestion || '先完成三次真实复盘'}}</view>
        </view>
      </view>
      <view class="handoff-script">{{assistantHandoff.scriptSuggestion || '完成一次真实复盘后，这里会生成助教承接摘要。'}}</view>
      <view class="handoff-summary">{{assistantHandoff.handoffSummary || '测评、复盘、训练和活镜变化会在这里汇成助教承接摘要。'}}</view>
      <view class="handoff-rows" wx:if="{{assistantHandoff.summaryRows && assistantHandoff.summaryRows.length}}">
        <view wx:for="{{assistantHandoff.summaryRows}}" wx:key="label">
          <text>{{item.label}}</text>
          <view>{{item.value}}</view>
        </view>
      </view>
      <view class="handoff-actions">
        <button bindtap="copyAssistantHandoff">复制承接摘要</button>
        <button data-type="daily_mantra" bindtap="generateShareCard">生成心证卡</button>
      </view>
      <view class="handoff-events" wx:if="{{assistantHandoff.eventTimeline.length}}">
        <view wx:for="{{assistantHandoff.eventTimeline}}" wx:key="id">
          <text>{{item.label}}</text>
          <view>{{item.detail}}</view>
        </view>
      </view>
    </view>

    <view class="growth-card card" bindtap="tapMenu" data-key="growth">
      <view class="growth-head">
        <view>
          <text>修行成长树</text>
          <view>{{growth.activeGate.name}} · {{growth.stateLabel}}</view>
        </view>
        <text>{{growth.overall}}</text>
      </view>
      <view class="growth-bar"><view style="width: {{growth.overall}}%;"></view></view>
      <view class="growth-next">下一步：{{growth.nextAction}} · {{continuity.milestone.label}}还差{{continuity.milestone.remaining}}日</view>
    </view>

    <view class="membership-card card">
      <view class="membership-head">
        <view>
          <text>会员修行体系</text>
          <view>{{retentionView.membership.current.name}}</view>
        </view>
        <text>{{retentionView.longTraining.title}}</text>
      </view>
      <view class="membership-note">{{retentionView.membership.current.note}}</view>
      <view class="benefit-list">
        <view wx:for="{{retentionView.membership.benefits}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="growth-bar"><view style="width: {{retentionView.membership.progress}}%;"></view></view>
      <view class="growth-next">{{retentionView.membership.nextText}}</view>
    </view>

    <view class="subscription-card card">
      <view class="subscription-head">
        <view>
          <text>订阅与同修身份</text>
          <view>{{subscriptionView.proof.identityName}}</view>
        </view>
        <text>{{subscriptionView.statusText}}</text>
      </view>
      <view class="identity-proof">
        <view class="proof-seal">修</view>
        <view>
          <text>{{subscriptionView.proof.planName}}</text>
          <view>{{subscriptionView.proof.proofNo}}</view>
          <view>{{subscriptionView.proof.validText}}</view>
        </view>
      </view>
      <view class="subscription-plans">
        <button
          wx:for="{{subscriptionView.plans}}"
          wx:key="key"
          class="{{item.active ? 'active' : ''}}"
          data-key="{{item.key}}"
          bindtap="selectSubscriptionPlan"
        >
          <text>{{item.name}}</text>
          <view>{{item.durationLabel}} · {{item.cadence}}</view>
        </button>
      </view>
      <view class="subscription-note">{{subscriptionView.current.note}}</view>
      <button class="identity-proof-btn" bindtap="generateMembershipIdentity">生成同修身份证明</button>
    </view>

    <view class="retention-panel card">
      <view class="retention-row">
        <view>
          <text>每日轻提醒</text>
          <view>{{retentionView.reminder.hint}}</view>
        </view>
        <switch checked="{{retentionView.reminder.enabled}}" color="#d8b76f" bindchange="toggleReminder" />
      </view>
      <picker mode="time" value="{{retentionView.reminder.time}}" bindchange="changeReminderTime">
        <view class="time-picker">
          <text>提醒时间</text>
          <view>{{retentionView.reminder.label}}</view>
        </view>
      </picker>
    </view>

    <view class="retention-panel card">
      <view class="retention-row">
        <view>
          <text>复测变化</text>
          <view>{{retentionView.retest.hint}}</view>
        </view>
        <button class="mini-action {{retentionView.retest.due ? 'due' : ''}}" bindtap="goAssessment">{{retentionView.retest.actionText}}</button>
      </view>
      <view class="time-picker" bindtap="goContent365">
        <text>全年修行</text>
        <view>{{retentionView.content365.subtitle}} · {{retentionView.content365.nextText}}</view>
      </view>
    </view>

    <view class="sync-card card">
      <view class="sync-head">
        <view>
          <text>数据同步</text>
          <view>{{syncView.message}}</view>
        </view>
        <text class="{{syncView.statusClass}}">{{syncView.statusText}}</text>
      </view>
      <view class="sync-user-tip">{{syncView.detail}}</view>
      <view wx:if="{{authFallback.visible}}" class="auth-fallback">
        <text>{{authFallback.title}}</text>
        <view>{{authFallback.text}}</view>
        <view class="auth-fallback-actions">
          <button bindtap="goReportFallback">返回心镜报告</button>
          <button bindtap="goPracticeFallback">继续今日修行</button>
          <button bindtap="syncNow">重新连接</button>
        </view>
      </view>
      <view class="sync-actions">
        <button class="secondary-btn" bindtap="pullNow">拉取档案</button>
        <button class="primary-btn" bindtap="syncNow">重新连接</button>
      </view>
      <view wx:if="{{debugMode}}" class="debug-sync-panel">
        <text>开发调试</text>
        <label class="form-label">后端地址</label>
        <input class="input-field" value="{{apiBase}}" bindinput="inputApiBase" placeholder="http://电脑局域网IP:8787" />
        <view class="debug-sync-actions">
          <button class="ghost-btn" bindtap="saveApiBase">保存地址</button>
          <button class="secondary-btn" bindtap="pullNow">拉取</button>
          <button class="primary-btn" bindtap="syncNow">同步</button>
        </view>
        <view wx:if="{{syncView.showTechnical}}" class="debug-technical">{{syncView.technicalMessage}}</view>
        <text class="sync-tip">开发者工具可用 127.0.0.1；手机真机预览请改成电脑局域网 IP，并确认后端服务已启动。</text>
      </view>
    </view>

    <view class="card-album card">
      <view class="card-album-head">
        <view>
          <text>我的心证卡册</text>
          <view>{{shareCards.length ? '已沉淀今日照见' : '生成第一张心证卡后会出现在这里'}}</view>
        </view>
        <button bindtap="generateInviteCard">邀同修照见</button>
      </view>
      <view class="card-album-actions">
        <button data-type="daily_mantra" bindtap="generateShareCard">分享心证卡</button>
        <button data-type="personality_mirror" bindtap="generateShareCard">同修镜像卡</button>
        <button data-type="group_practice" bindtap="generateShareCard">群内共修卡</button>
        <button data-type="retest_change" bindtap="generateShareCard">复测变化卡</button>
      </view>
      <view class="share-moment-panel">
        <view class="share-moment-title">
          <text>12 个自然分享时刻</text>
          <view>从被照见，到邀同修照见</view>
        </view>
        <view class="share-moment-grid">
          <button
            wx:for="{{shareMoments}}"
            wx:key="key"
            data-key="{{item.key}}"
            data-type="{{item.cardType}}"
            bindtap="generateMomentCard"
          >
            <text>{{item.label}}</text>
            <view>{{item.title}}</view>
            <text>{{item.cardLabel}}</text>
          </button>
        </view>
      </view>
      <view class="card-album-list" wx:if="{{shareCards.length}}">
        <view wx:for="{{shareCards}}" wx:key="id">
          <text>{{item.typeLabel}}</text>
          <view>{{item.headline}}</view>
        </view>
      </view>
    </view>

    <view class="card-album card">
      <view class="card-album-head">
        <view>
          <text>讲堂与同修记录</text>
          <view>{{lessonReservations.length}} 条预约 · {{lessonWatchRecords.length}} 条观看 · {{inviteEvents.length}} 条同修邀请</view>
        </view>
      </view>
      <view class="card-album-list">
        <view>
          <text>共修局</text>
          <view>{{groupPractice.groupCode || '待生成'}} · {{groupPractice.memberCount || 1}} 位同修 · 今日{{trainingDone || 0}}步记录</view>
        </view>
        <view wx:if="{{companionMirror.ready}}">
          <text>同修镜像</text>
          <view>我：{{companionMirror.inviteePrimary}} · 同修：{{companionMirror.inviterPrimary}}</view>
        </view>
        <view wx:if="{{retestSnapshots.baseline || retestSnapshots.retest}}">
          <text>复测快照</text>
          <view>Day1：{{retestSnapshots.baseline.primary || '待初测'}} · Day7：{{retestSnapshots.retest.primary || '待复测'}}</view>
        </view>
      </view>
      <view class="card-album-list" wx:if="{{lessonReservations.length}}">
        <view wx:for="{{lessonReservations}}" wx:key="id">
          <text>{{item.typeLabel || item.type || '课程'}}</text>
          <view>{{item.title}}</view>
        </view>
      </view>
      <view class="card-album-list" wx:if="{{lessonWatchRecords.length}}">
        <view wx:for="{{lessonWatchRecords}}" wx:key="id">
          <text>已看完</text>
          <view>{{item.title}}</view>
        </view>
      </view>
      <view class="card-album-list" wx:if="{{inviteEvents.length}}">
        <view wx:for="{{inviteEvents}}" wx:key="id">
          <text>{{item.sourceScene || '同修邀请'}}</text>
          <view>{{item.shareCardType || item.cardType || 'companion_invite'}} · {{item.assessmentCompleted ? '已照见' : '待照见'}} · {{item.day7Completed ? '七日完成' : item.day3Completed ? '三日连修' : item.day1Completed ? 'Day1完成' : '训练未完成'}}</view>
        </view>
      </view>
    </view>

    <view class="section-title">
      <view>我的闭环</view>
      <text>留存路径</text>
    </view>

    <view class="menu-list card">
      <button wx:for="{{menu}}" wx:key="key" class="menu-row" data-key="{{item.key}}" bindtap="tapMenu">
        <view>
          <text>{{item.title}}</text>
          <text>{{item.subtitle}}</text>
        </view>
        <text class="chevron">进入</text>
      </button>
    </view>

    <view class="mission-card card">
      <text>小程序定位</text>
      <view>阳明心学交易系统 · 高频陪跑端：每日心证、训练打卡、交易截图上传、真实复盘、活镜提醒、助教承接与订阅提醒。网页负责深度照见，小程序负责每天记录一次真实反应并推动下一次训练。</view>
    </view>
    <button class="danger-clear" bindtap="clearLocalData">清理本地训练数据</button>

    <compliance-notice />
  </view>
  <bottom-tab-bar active="profile" />
</view>
