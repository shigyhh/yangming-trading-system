.mirror-card,
.empty-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.mirror-card text,
.mirror-card view,
.mirror-card button,
.empty-card text,
.empty-card view,
.empty-card button,
.archive-head,
.record-row {
  position: relative;
  z-index: 1;
}

.mirror-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.mirror-head view text,
.archive-head text {
  display: block;
  color: #f1d27d;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.mirror-head view view {
  margin-top: 10rpx;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", serif;
  font-size: 38rpx;
  line-height: 1.3;
}

.mirror-head > text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: rgba(241, 210, 125, 0.76);
  border: 1rpx solid rgba(241, 210, 125, 0.18);
  background: rgba(255, 255, 255, 0.035);
  font-size: 21rpx;
  font-weight: 900;
}

.mirror-line {
  margin-top: 20rpx;
  color: rgba(247, 239, 223, 0.7);
  font-size: 25rpx;
  line-height: 1.62;
}

.mirror-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.mirror-grid > view {
  padding: 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(247, 239, 223, 0.1);
  background: rgba(255, 255, 255, 0.035);
}

.mirror-grid text {
  display: block;
  color: #b49355;
  font-size: 21rpx;
  font-weight: 900;
}

.mirror-grid view view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.88);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 900;
}

.mirror-grid view text:last-child {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.48);
  font-size: 21rpx;
  line-height: 1.45;
  font-weight: 700;
}

.archive-head {
  margin: 42rpx 0 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.archive-head view {
  color: rgba(247, 239, 223, 0.48);
  font-size: 23rpx;
  font-weight: 800;
}

.record-list {
  display: grid;
  gap: 16rpx;
}

.record-row {
  width: 100%;
  min-height: 150rpx;
  padding: 22rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 154rpx;
  gap: 18rpx;
  align-items: center;
  text-align: left;
}

.record-row::before,
.record-row::after {
  display: none;
}

.record-main text {
  display: block;
  color: #fff6e6;
  font-size: 27rpx;
  font-weight: 900;
}

.record-main view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.56);
  font-size: 22rpx;
  line-height: 1.45;
}

.record-side {
  text-align: right;
}

.record-side text {
  display: block;
  color: #f1d27d;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.35;
}

.record-side view {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.42);
  font-size: 20rpx;
  line-height: 1.4;
}

.empty-card view {
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", serif;
  font-size: 34rpx;
  line-height: 1.35;
}

.empty-card text {
  display: block;
  margin-top: 14rpx;
  color: rgba(247, 239, 223, 0.6);
  font-size: 24rpx;
  line-height: 1.6;
}

.empty-card button {
  margin-top: 22rpx;
}

@media (max-width: 340px) {
  .record-row {
    grid-template-columns: 1fr;
  }

  .record-side {
    text-align: left;
  }
}
