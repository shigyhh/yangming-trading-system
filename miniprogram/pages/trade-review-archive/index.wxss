.archive-bridge,
.closure-ledger-card,
.ledger-card,
.mirror-card,
.empty-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.archive-bridge,
.archive-bridge view,
.closure-ledger-card text,
.closure-ledger-card view,
.ledger-card text,
.ledger-card view,
.mirror-card text,
.mirror-card view,
.mirror-card button,
.empty-card text,
.empty-card view,
.empty-card button,
.archive-head,
.record-row {
  position: relative;
  z-index: 1;
}

.archive-bridge {
  padding: 24rpx;
  border-color: rgba(88, 194, 173, 0.16);
  background:
    radial-gradient(circle at 88% 0%, rgba(88, 194, 173, 0.1), transparent 42%),
    rgba(255, 255, 255, 0.035);
}

.archive-bridge view {
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 28rpx;
  line-height: 1.55;
  font-weight: 900;
}

.closure-chain-list {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  display: grid;
  gap: 12rpx;
}

.closure-chain-list > view {
  min-height: 94rpx;
  padding: 16rpx;
  display: grid;
  grid-template-columns: 46rpx minmax(0, 1fr) 104rpx;
  gap: 14rpx;
  align-items: center;
  border-radius: 18rpx;
  border: 1rpx solid rgba(247, 239, 223, 0.08);
  background: rgba(255, 255, 255, 0.03);
}

.closure-chain-list > view.done {
  border-color: rgba(88, 194, 173, 0.18);
  background: rgba(88, 194, 173, 0.055);
}

.closure-chain-list > view.current {
  border-color: rgba(216, 183, 111, 0.26);
  background: rgba(216, 183, 111, 0.07);
}

.closure-chain-list > view > text:first-child {
  width: 42rpx;
  height: 42rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: rgba(247, 239, 223, 0.58);
  border: 1rpx solid rgba(216, 183, 111, 0.16);
  font-size: 20rpx;
  font-weight: 900;
}

.closure-chain-list > view.done > text:first-child,
.closure-chain-list > view.current > text:first-child {
  color: #11130d;
  border-color: transparent;
  background: linear-gradient(180deg, #ead089, #c69846);
}

.closure-chain-list view view text {
  display: block;
  color: #fff6e6;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 900;
}

.closure-chain-list view view view {
  margin-top: 6rpx;
  color: rgba(247, 239, 223, 0.5);
  font-size: 21rpx;
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.closure-chain-list > view > text:last-child {
  color: rgba(247, 239, 223, 0.42);
  font-size: 20rpx;
  line-height: 1.35;
  text-align: right;
  font-weight: 900;
}

.closure-chain-list > view.done > text:last-child {
  color: rgba(88, 194, 173, 0.86);
}

.closure-chain-list > view.current > text:last-child {
  color: #f1d27d;
}

.closure-next-action {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-left: 4rpx solid rgba(216, 183, 111, 0.44);
  border-radius: 14rpx;
  color: rgba(247, 239, 223, 0.72);
  background: rgba(216, 183, 111, 0.055);
  font-size: 23rpx;
  line-height: 1.5;
  font-weight: 900;
}

.ledger-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.ledger-head text,
.ledger-row text:first-child {
  display: block;
  color: #f1d27d;
  font-size: 23rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
}

.ledger-head view view {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.54);
  font-size: 23rpx;
  line-height: 1.45;
}

.ledger-head > text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(241, 210, 125, 0.18);
  background: rgba(255, 255, 255, 0.035);
  color: rgba(241, 210, 125, 0.76);
  font-size: 21rpx;
}

.ledger-list {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240rpx, 1fr));
  gap: 14rpx;
}

.ledger-row {
  min-width: 240rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(247, 239, 223, 0.1);
  background: rgba(255, 255, 255, 0.035);
}

.ledger-row view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.76);
  font-size: 23rpx;
  line-height: 1.45;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.ledger-row view + view {
  color: rgba(247, 239, 223, 0.48);
  -webkit-line-clamp: 3;
}

.ledger-row text:last-child,
.ledger-empty {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.42);
  font-size: 21rpx;
  line-height: 1.5;
}

.mirror-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.mirror-head view text,
.archive-head text {
  display: block;
  color: #f1d27d;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.mirror-head view view {
  margin-top: 10rpx;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", serif;
  font-size: 38rpx;
  line-height: 1.3;
}

.mirror-head > text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: rgba(241, 210, 125, 0.76);
  border: 1rpx solid rgba(241, 210, 125, 0.18);
  background: rgba(255, 255, 255, 0.035);
  font-size: 21rpx;
  font-weight: 900;
}

.mirror-line {
  margin-top: 20rpx;
  color: rgba(247, 239, 223, 0.7);
  font-size: 25rpx;
  line-height: 1.62;
}

.mirror-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.mirror-grid > view {
  padding: 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(247, 239, 223, 0.1);
  background: rgba(255, 255, 255, 0.035);
}

.mirror-grid text {
  display: block;
  color: #b49355;
  font-size: 21rpx;
  font-weight: 900;
}

.mirror-grid view view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.88);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 900;
}

.mirror-grid view text:last-child {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.48);
  font-size: 21rpx;
  line-height: 1.45;
  font-weight: 700;
}

.archive-head {
  margin: 42rpx 0 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.archive-head view {
  color: rgba(247, 239, 223, 0.48);
  font-size: 23rpx;
  font-weight: 800;
}

.record-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240rpx, 1fr));
  gap: 16rpx;
}

.record-row {
  width: 100%;
  min-width: 240rpx;
  min-height: 190rpx;
  padding: 22rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 14rpx;
  align-items: start;
  text-align: left;
}

.record-row::before,
.record-row::after {
  display: none;
}

.record-main text {
  display: block;
  color: #fff6e6;
  font-size: 27rpx;
  font-weight: 900;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-main view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.56);
  font-size: 22rpx;
  line-height: 1.45;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-side {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
  text-align: left;
}

.record-side text {
  display: block;
  max-width: 58%;
  color: #f1d27d;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.35;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.record-side view {
  margin-top: 0;
  color: rgba(247, 239, 223, 0.42);
  font-size: 20rpx;
  line-height: 1.4;
  white-space: nowrap;
}

.empty-card view {
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", serif;
  font-size: 34rpx;
  line-height: 1.35;
}

.empty-card text {
  display: block;
  margin-top: 14rpx;
  color: rgba(247, 239, 223, 0.6);
  font-size: 24rpx;
  line-height: 1.6;
}

.empty-card button {
  margin-top: 22rpx;
}

@media (max-width: 340px) {
  .record-row {
    grid-template-columns: 1fr;
  }

  .record-side {
    text-align: left;
  }
}
