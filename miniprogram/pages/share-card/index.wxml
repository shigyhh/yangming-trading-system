<view class="share-shell {{posterMode ? 'poster-mode' : 'browse-mode'}}">
  <view class="share-bg mist"></view>
  <view class="share-bg grain"></view>

  <view wx:if="{{!posterMode}}" class="share-content">
    <view class="nav-head">
      <button class="nav-back" bindtap="goBack">‹</button>
      <view class="head">
        <view class="seal">证</view>
        <view>
          <text class="head-title">心证卡</text>
          <view class="head-subtitle">被照见之后，才自然愿意分享。</view>
        </view>
      </view>
      <button class="poster-entry" bindtap="openPosterMode">海报模式</button>
    </view>

    <scroll-view scroll-x class="type-strip" show-scrollbar="{{false}}">
      <button
        wx:for="{{cardTypes}}"
        wx:key="type"
        data-type="{{item.type}}"
        class="card-type-button {{item.active ? 'active' : ''}}"
        bindtap="switchType"
      >{{item.title}}</button>
    </scroll-view>

    <view class="card-preview">
      <view class="card-top">
        <view>
          <text class="card-top-label">{{card.typeLabel}}</text>
          <view class="card-top-brand">阳明心学交易系统</view>
        </view>
        <view class="mini-seal">知</view>
      </view>
      <view class="headline">{{card.headline}}</view>
      <view class="body">{{card.body}}</view>
      <view class="metrics" wx:if="{{card.metrics && card.metrics.length}}">
        <view wx:for="{{card.metrics}}" wx:key="label" class="metric-row">
          <text class="metric-label">{{item.label}}</text>
          <view class="metric-value">{{item.value}}</view>
          <text wx:if="{{item.trend}}" class="metric-trend">{{item.trend}}</text>
        </view>
      </view>
      <view class="insight">{{card.insight}}</view>
      <view class="card-foot">
        <text class="card-cta">{{card.cta}}</text>
        <view class="card-source">同修照见</view>
      </view>
    </view>

    <view class="share-actions">
      <button class="secondary" bindtap="saveCard">{{saved ? '已存入卡册' : '保存心证卡'}}</button>
      <button class="primary" open-type="share" bindtap="inviteCompanion">邀一位同修同行</button>
    </view>
    <button class="poster-action" bindtap="openPosterMode">进入纯净海报截图</button>
    <button class="ghost copy-action" bindtap="copyShareText">复制分享文案</button>

    <view class="ledger-card">
      <view class="album-head">
        <text class="album-title">来自闭环证据</text>
        <view class="album-link">{{evidenceSummary.total ? evidenceSummary.total + ' 条证据' : '今日落印后生成第一条证据'}}</view>
      </view>
      <view wx:if="{{evidenceRows.length}}" class="ledger-list">
        <view wx:for="{{evidenceRows}}" wx:key="id" class="ledger-row">
          <text class="ledger-type">{{item.typeLabel}}</text>
          <view class="ledger-title">{{item.title}}</view>
        </view>
      </view>
      <view wx:else class="ledger-empty">这里还没有心证。完成今日落印后，第一枚心证会存入档案。</view>
    </view>

    <view class="album-card" wx:if="{{album.length}}">
      <view class="album-head">
        <text class="album-title">我的心证卡册</text>
        <view class="album-link" bindtap="goProfile">去用户中心</view>
      </view>
      <view class="album-list">
        <view wx:for="{{album}}" wx:key="id" class="album-row">
          <text class="album-type">{{item.typeLabel}}</text>
          <view class="album-value">{{item.headline}}</view>
        </view>
      </view>
    </view>

    <view class="compliance-card">{{card.compliance}}</view>
    <button class="ghost" bindtap="goHome">回到今日陪跑</button>
  </view>

  <view wx:else class="poster-page">
    <view class="poster-card poster-master">
      <view class="poster-ink"></view>
      <view class="poster-brand">
        <view class="poster-brand-seal">知</view>
        <view class="poster-brand-copy">
          <text class="poster-brand-title">{{posterCard.brandTitle}}</text>
          <view class="poster-brand-subtitle">{{posterCard.brandSubtitle}}</view>
        </view>
      </view>

      <view class="poster-label">{{posterCard.posterLabel}}</view>
      <view class="poster-heart-proof">{{posterCard.heartProof}}</view>

      <view class="poster-section-grid">
        <view class="poster-section">
          <text class="poster-section-label">主镜</text>
          <view class="poster-section-value">{{posterCard.primaryMirror}}</view>
        </view>
        <view class="poster-section">
          <text class="poster-section-label">今日修行</text>
          <view class="poster-section-value">{{posterCard.practice}}</view>
        </view>
      </view>

      <view class="poster-imprint">
        <text class="poster-imprint-label">今日印记</text>
        <view class="poster-imprint-seals">
          <text class="poster-imprint-seal">志</text>
          <text class="poster-imprint-seal">止</text>
          <text class="poster-imprint-seal">照</text>
        </view>
      </view>

      <view class="poster-quiet-line">{{posterCard.insight}}</view>

      <view class="poster-signature">
        <text class="poster-signature-title">{{posterCard.signature}}</text>
        <view class="poster-signature-no">心证编号 · {{posterCard.posterNo}}</view>
      </view>
    </view>
  </view>

  <bottom-tab-bar wx:if="{{!posterMode}}" active="zhixing" />
</view>
