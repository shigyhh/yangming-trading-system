.share-shell {
  min-height: 100vh;
  background: #07100e;
  color: #f5ead8;
  position: relative;
  overflow: hidden;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.share-shell.poster-mode {
  height: 100vh;
  padding-bottom: 0;
}

.share-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.share-bg.mist {
  background:
    radial-gradient(circle at 50% 4%, rgba(216, 183, 111, 0.14), transparent 34%),
    radial-gradient(circle at 100% 28%, rgba(95, 132, 117, 0.13), transparent 36%),
    linear-gradient(180deg, #11120e 0%, #07100e 55%, #040706 100%);
}

.share-bg.grain {
  opacity: 0.2;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.026) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
  background-size: 34rpx 34rpx;
}

.share-content {
  position: relative;
  z-index: 1;
  padding: calc(22rpx + env(safe-area-inset-top)) 32rpx 40rpx;
}

.nav-head {
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.nav-back,
.poster-entry {
  min-height: 60rpx;
  border-radius: 999rpx;
  color: rgba(245, 234, 216, 0.72);
  background: rgba(255, 255, 255, 0.045);
  border: 1rpx solid rgba(217, 189, 122, 0.14);
  font-weight: 700;
}

.nav-back {
  width: 64rpx;
  padding: 0;
  display: grid;
  place-items: center;
  font-size: 50rpx;
  line-height: 1;
}

.poster-entry {
  padding: 0 20rpx;
  font-size: 23rpx;
}

.nav-back::after,
.poster-entry::after,
.poster-action::after {
  display: none;
}

.head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.nav-head .head {
  margin-bottom: 0;
}

.seal,
.mini-seal {
  display: grid;
  place-items: center;
  color: #d8b76f;
  font-family: "LXGW WenKai", "Songti SC", serif;
  border: 1rpx solid rgba(216, 183, 111, 0.34);
  background: rgba(255, 255, 255, 0.04);
}

.seal {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  font-size: 36rpx;
}

.head-title {
  display: block;
  font-size: 36rpx;
  font-weight: 650;
}

.head-subtitle {
  margin-top: 8rpx;
  color: rgba(245, 234, 216, 0.52);
  font-size: 24rpx;
}

.type-strip {
  white-space: nowrap;
  margin: 0 -32rpx 28rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.card-type-button {
  display: inline-flex;
  align-items: center;
  min-height: 58rpx;
  margin: 0 12rpx 0 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: rgba(245, 234, 216, 0.7);
  background: rgba(255, 255, 255, 0.045);
  border: 1rpx solid rgba(217, 189, 122, 0.14);
  font-size: 24rpx;
}

.card-type-button.active {
  color: #1c160d;
  background: linear-gradient(135deg, #e6c979, #a9823c);
}

.card-preview {
  min-height: 740rpx;
  padding: 44rpx 38rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.22);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018)),
    radial-gradient(circle at 50% 0%, rgba(216, 183, 111, 0.12), transparent 45%),
    rgba(9, 16, 13, 0.84);
  box-shadow: 0 36rpx 90rpx rgba(0, 0, 0, 0.32);
}

.heart-proof-loading {
  min-height: 500rpx;
  padding: 64rpx 38rpx 44rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  text-align: center;
  border-radius: 30rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.14);
  background:
    radial-gradient(circle at 50% 0%, rgba(216, 183, 111, 0.1), transparent 44%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.014)),
    rgba(9, 16, 13, 0.78);
  box-shadow: 0 28rpx 72rpx rgba(0, 0, 0, 0.24);
}

.loading-breath {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: rgba(216, 183, 111, 0.72);
  box-shadow: 0 0 34rpx rgba(216, 183, 111, 0.24);
  animation: loadingBreath 1.1s ease-in-out infinite;
}

.heart-proof-loading text {
  display: block;
  margin-top: 28rpx;
  color: rgba(255, 250, 235, 0.9);
  font-family: "LXGW WenKai", "Songti SC", serif;
  font-size: 40rpx;
  font-weight: 650;
  line-height: 1.32;
}

.heart-proof-loading view:last-child {
  margin-top: 14rpx;
  color: rgba(245, 234, 216, 0.54);
  font-size: 24rpx;
  line-height: 1.5;
}

.heart-proof-fallback {
  min-height: 560rpx;
  padding: 64rpx 38rpx 44rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  text-align: center;
  border-radius: 30rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.2);
  background:
    radial-gradient(circle at 50% 0%, rgba(216, 183, 111, 0.13), transparent 46%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.052), rgba(255, 255, 255, 0.018)),
    rgba(9, 16, 13, 0.84);
  box-shadow: 0 32rpx 80rpx rgba(0, 0, 0, 0.28);
}

.fallback-seal {
  width: 92rpx;
  height: 92rpx;
  display: grid;
  place-items: center;
  border-radius: 28rpx;
  color: rgba(255, 236, 205, 0.92);
  border: 2rpx solid rgba(120, 60, 45, 0.62);
  background: rgba(120, 60, 45, 0.3);
  font-family: "LXGW WenKai", "Songti SC", serif;
  font-size: 50rpx;
  transform: rotate(-5deg);
}

.heart-proof-fallback > text {
  display: block;
  margin-top: 30rpx;
  color: rgba(255, 250, 235, 0.94);
  font-family: "LXGW WenKai", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 650;
  line-height: 1.32;
}

.fallback-lines {
  margin-top: 22rpx;
  color: rgba(245, 234, 216, 0.62);
  font-size: 26rpx;
  line-height: 1.62;
}

.fallback-actions {
  width: 100%;
  margin-top: 42rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.fallback-actions button {
  min-height: 80rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.local-sync-hint {
  margin-bottom: 18rpx;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  color: rgba(216, 183, 111, 0.78);
  border: 1rpx solid rgba(217, 189, 122, 0.14);
  background: rgba(216, 183, 111, 0.055);
  font-size: 22rpx;
  line-height: 1.4;
  text-align: center;
}

@keyframes loadingBreath {
  0%,
  100% {
    opacity: 0.42;
    transform: scale(0.86);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}

.card-top,
.card-foot,
.album-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
}

.card-top-label {
  color: rgba(216, 183, 111, 0.72);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.card-top-brand {
  margin-top: 8rpx;
  color: rgba(245, 234, 216, 0.42);
  font-size: 22rpx;
}

.mini-seal {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
}

.mini-seal.brand-zhao-mini {
  font-size: 0;
  gap: 5rpx;
  color: rgba(216, 183, 111, 0.84);
}

.mini-seal.brand-zhao-mini .zhao-eye {
  width: 14rpx;
  height: 13rpx;
  border-width: 2rpx;
}

.mini-seal.brand-zhao-mini .zhao-mirror {
  width: 36rpx;
}

.mini-seal.brand-zhao-mini .zhao-fire {
  gap: 15rpx;
}

.mini-seal.brand-zhao-mini .zhao-fire-dot {
  width: 3rpx;
  height: 15rpx;
}

.headline {
  margin-top: 64rpx;
  font-size: 48rpx;
  line-height: 1.28;
  font-family: "LXGW WenKai", "Songti SC", serif;
  color: rgba(255, 250, 235, 0.96);
  white-space: pre-line;
}

.body {
  margin-top: 32rpx;
  color: rgba(245, 234, 216, 0.66);
  font-size: 28rpx;
  line-height: 1.72;
  white-space: pre-line;
}

.metrics {
  display: grid;
  gap: 14rpx;
  margin-top: 30rpx;
}

.metric-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
}

.metric-label,
.metric-trend {
  color: rgba(245, 234, 216, 0.5);
  font-size: 23rpx;
}

.metric-value {
  color: #d8b76f;
  font-size: 28rpx;
  font-weight: 650;
}

.insight {
  margin-top: 34rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(95, 132, 117, 0.24);
  color: rgba(245, 234, 216, 0.76);
  background: rgba(95, 132, 117, 0.08);
  font-size: 26rpx;
  line-height: 1.65;
}

.card-foot {
  margin-top: 46rpx;
  color: rgba(216, 183, 111, 0.82);
  font-size: 24rpx;
}

.card-source {
  color: rgba(245, 234, 216, 0.38);
}

.share-actions {
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.share-actions .primary,
.share-actions .secondary,
.ghost,
.poster-action {
  min-height: 84rpx;
  border-radius: 22rpx;
  font-weight: 650;
  font-size: 26rpx;
}

.primary {
  color: #1c160d;
  background: linear-gradient(135deg, #e6c979, #a9823c);
}

.secondary,
.ghost,
.poster-action {
  color: rgba(245, 234, 216, 0.78);
  background: rgba(255, 255, 255, 0.045);
  border: 1rpx solid rgba(217, 189, 122, 0.18);
}

.poster-action {
  width: 100%;
  margin-top: 18rpx;
  color: #d8b76f;
  background:
    linear-gradient(180deg, rgba(216, 183, 111, 0.08), rgba(255, 255, 255, 0.025)),
    rgba(0, 0, 0, 0.18);
}

.ledger-card,
.album-card,
.compliance-card {
  margin-top: 24rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.14);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.035);
  padding: 28rpx;
}

.ledger-list {
  display: grid;
  gap: 14rpx;
  margin-top: 20rpx;
}

.ledger-row {
  min-width: 240rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.12);
  background: rgba(0, 0, 0, 0.16);
}

.ledger-type {
  display: block;
  color: rgba(216, 183, 111, 0.72);
  font-size: 22rpx;
  font-weight: 650;
}

.ledger-title,
.ledger-empty {
  margin-top: 8rpx;
  color: rgba(245, 234, 216, 0.58);
  font-size: 24rpx;
  line-height: 1.45;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.album-title {
  font-size: 28rpx;
  font-weight: 650;
}

.album-link {
  color: #d8b76f;
  font-size: 24rpx;
}

.album-list {
  display: grid;
  gap: 14rpx;
  margin-top: 20rpx;
}

.album-row {
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.album-type {
  color: rgba(216, 183, 111, 0.72);
  font-size: 22rpx;
}

.album-value {
  margin-top: 8rpx;
  color: rgba(245, 234, 216, 0.62);
  font-size: 25rpx;
  line-height: 1.45;
}

.compliance-card {
  color: rgba(245, 234, 216, 0.42);
  font-size: 22rpx;
  line-height: 1.6;
}

.ghost {
  width: 100%;
  margin-top: 18rpx;
}

.copy-action {
  margin-top: 18rpx;
}

.poster-page {
  position: fixed;
  inset: 0;
  z-index: 4;
  padding: calc(58rpx + env(safe-area-inset-top)) 34rpx calc(58rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 50% 8%, rgba(216, 183, 111, 0.12), transparent 32%),
    radial-gradient(circle at 100% 78%, rgba(95, 132, 117, 0.1), transparent 36%),
    linear-gradient(180deg, #0f120d 0%, #07100e 54%, #030505 100%);
}

.poster-mode .share-bg,
.poster-mode .share-content {
  display: none;
}

.poster-card {
  position: relative;
  width: 654rpx;
  max-width: 100%;
  min-height: 1040rpx;
  max-height: calc(100vh - 64rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  padding: 48rpx 42rpx 34rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 34rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.28);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.064), rgba(255, 255, 255, 0.018)),
    radial-gradient(circle at 50% 0%, rgba(216, 183, 111, 0.17), transparent 36%),
    radial-gradient(circle at 12% 88%, rgba(95, 132, 117, 0.11), transparent 38%),
    rgba(8, 15, 12, 0.96);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.09),
    0 46rpx 120rpx rgba(0, 0, 0, 0.46);
}

.poster-master {
  width: 666rpx;
  min-height: 1010rpx;
  max-height: calc(100vh - 116rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  padding: 52rpx 44rpx 40rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(216, 183, 111, 0.16), transparent 34%),
    radial-gradient(circle at 8% 92%, rgba(95, 132, 117, 0.12), transparent 38%),
    linear-gradient(180deg, rgba(244, 235, 221, 0.064), rgba(244, 235, 221, 0.014)),
    #08100d;
}

.poster-brand {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.poster-brand-seal {
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  border-radius: 22rpx;
  color: #f0d58b;
  border: 1rpx solid rgba(216, 183, 111, 0.34);
  background:
    radial-gradient(circle at 50% 42%, rgba(216, 183, 111, 0.16), transparent 58%),
    rgba(255, 255, 255, 0.04);
  font-family: "LXGW WenKai", "Songti SC", serif;
  font-size: 36rpx;
}

.poster-brand-seal.brand-zhao-mini {
  font-size: 0;
  gap: 6rpx;
  color: rgba(240, 213, 139, 0.88);
}

.poster-brand-seal.brand-zhao-mini .zhao-eye {
  width: 16rpx;
  height: 14rpx;
  border-width: 2rpx;
}

.poster-brand-seal.brand-zhao-mini .zhao-mirror {
  width: 42rpx;
}

.poster-brand-seal.brand-zhao-mini .zhao-fire {
  gap: 18rpx;
}

.poster-brand-seal.brand-zhao-mini .zhao-fire-dot {
  width: 3rpx;
  height: 18rpx;
}

.poster-brand-copy {
  min-width: 0;
}

.poster-brand-title {
  display: block;
  color: rgba(255, 250, 235, 0.9);
  font-size: 28rpx;
  font-weight: 850;
  letter-spacing: 0.08em;
}

.poster-brand-subtitle {
  margin-top: 8rpx;
  color: rgba(245, 234, 216, 0.42);
  font-size: 21rpx;
  font-weight: 700;
}

.poster-label {
  position: relative;
  z-index: 1;
  margin-top: 72rpx;
  color: rgba(216, 183, 111, 0.78);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.2em;
}

.poster-heart-proof {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  color: rgba(255, 250, 235, 0.98);
  font-family: "LXGW WenKai", "Songti SC", serif;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.28;
  white-space: pre-line;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.poster-section-grid {
  position: relative;
  z-index: 1;
  margin-top: 44rpx;
  display: grid;
  gap: 16rpx;
}

.poster-section {
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.12);
  background: rgba(255, 255, 255, 0.032);
}

.poster-section-label,
.poster-imprint-label {
  display: block;
  color: rgba(216, 183, 111, 0.66);
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.poster-section-value {
  margin-top: 10rpx;
  color: rgba(245, 234, 216, 0.82);
  font-size: 26rpx;
  font-weight: 750;
  line-height: 1.46;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.poster-imprint {
  position: relative;
  z-index: 1;
  margin-top: 32rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(120, 60, 45, 0.35);
  background: rgba(120, 60, 45, 0.1);
}

.poster-imprint-seals {
  display: flex;
  gap: 12rpx;
}

.poster-imprint-seal {
  width: 46rpx;
  height: 46rpx;
  display: grid;
  place-items: center;
  border-radius: 14rpx;
  color: rgba(244, 235, 221, 0.92);
  border: 1rpx solid rgba(120, 60, 45, 0.58);
  background: radial-gradient(circle at 50% 42%, rgba(120, 60, 45, 0.76), rgba(57, 20, 16, 0.44));
  font-family: "LXGW WenKai", "Songti SC", serif;
  font-size: 24rpx;
  font-weight: 900;
}

.poster-quiet-line {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  padding-left: 22rpx;
  border-left: 3rpx solid rgba(95, 132, 117, 0.56);
  color: rgba(245, 234, 216, 0.62);
  font-size: 25rpx;
  line-height: 1.58;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.poster-signature {
  position: relative;
  z-index: 1;
  margin-top: auto;
  padding-top: 34rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.poster-signature-title {
  display: block;
  color: rgba(216, 183, 111, 0.82);
  font-size: 24rpx;
  font-weight: 850;
  letter-spacing: 0.08em;
}

.poster-signature-no {
  margin-top: 10rpx;
  color: rgba(245, 234, 216, 0.36);
  font-size: 20rpx;
  line-height: 1.45;
}

.poster-ink {
  position: absolute;
  inset: 0;
  opacity: 0.18;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
  background-size: 32rpx 32rpx;
}

@media (max-width: 340px) {
  .poster-master {
    min-height: 940rpx;
    padding: 40rpx 34rpx 30rpx;
  }

  .poster-label {
    margin-top: 54rpx;
  }

  .poster-heart-proof {
    font-size: 45rpx;
  }

  .poster-section-value,
  .poster-quiet-line {
    font-size: 24rpx;
  }
}
