.kline-page {
  background:
    radial-gradient(circle at 82% 4%, rgba(216, 183, 111, 0.16), transparent 34%),
    radial-gradient(circle at 12% 34%, rgba(95, 132, 117, 0.14), transparent 38%),
    linear-gradient(180deg, #07100e 0%, #0a1110 46%, #070a09 100%);
}

.ink-depth {
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.58;
  background:
    linear-gradient(115deg, transparent 0 18%, rgba(244, 235, 221, 0.035) 19%, transparent 23% 100%),
    radial-gradient(ellipse at 50% 18%, rgba(244, 235, 221, 0.07), transparent 44%);
}

.kline-hero,
.mind-wave,
.method-card,
.practice-card,
.prescription-card,
.gate-card,
.completion-card {
  position: relative;
  z-index: 1;
}

.hero-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.hero-topline text {
  color: rgba(216, 183, 111, 0.82);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.34em;
}

.hero-topline view {
  min-width: 112rpx;
  height: 48rpx;
  display: grid;
  place-items: center;
  border: 1rpx solid rgba(216, 183, 111, 0.22);
  border-radius: 999rpx;
  color: rgba(244, 235, 221, 0.66);
  background: rgba(255, 255, 255, 0.045);
  font-size: 22rpx;
  font-weight: 800;
}

.kline-hero .page-title {
  margin-top: 26rpx;
  font-size: 58rpx;
  letter-spacing: 0;
}

.kline-hero .page-subtitle {
  max-width: 640rpx;
  color: rgba(244, 235, 221, 0.7);
  font-size: 25rpx;
  line-height: 1.58;
}

.kline-one-thing {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-left: 4rpx solid rgba(95, 132, 117, 0.64);
  border-radius: 0 22rpx 22rpx 0;
  background:
    linear-gradient(90deg, rgba(95, 132, 117, 0.13), rgba(244, 235, 221, 0.018));
}

.kline-one-thing text {
  display: block;
  color: rgba(216, 183, 111, 0.6);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.kline-one-thing view {
  margin-top: 8rpx;
  color: rgba(244, 235, 221, 0.84);
  font-size: 25rpx;
  font-weight: 850;
  line-height: 1.5;
}

.slice-switch {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.12);
  background: rgba(255, 255, 255, 0.035);
}

.slice-switch > view {
  min-width: 0;
}

.slice-switch text {
  display: block;
  color: rgba(244, 235, 221, 0.88);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.slice-switch view view {
  margin-top: 6rpx;
  color: rgba(244, 235, 221, 0.48);
  font-size: 20rpx;
  line-height: 1.42;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.slice-switch button {
  flex: 0 0 auto;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: rgba(216, 183, 111, 0.84);
  border: 1rpx solid rgba(217, 189, 122, 0.16);
  background: rgba(216, 183, 111, 0.055);
  font-size: 21rpx;
  font-weight: 900;
}

.hero-meta {
  margin-top: 34rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.hero-meta > view {
  min-height: 132rpx;
  padding: 20rpx 18rpx;
  border: 1rpx solid rgba(216, 183, 111, 0.16);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.045);
}

.hero-meta text,
.section-kicker,
.field-block > text,
.prescription-grid text,
.completion-card text:first-child {
  display: block;
  color: rgba(216, 183, 111, 0.76);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.hero-meta view view {
  margin-top: 12rpx;
  color: #fff6e6;
  font-size: 25rpx;
  line-height: 1.42;
  font-weight: 800;
}

.market-rail {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.market-chip {
  min-height: 112rpx;
  padding: 18rpx;
  display: block;
  text-align: left;
  border: 1rpx solid rgba(244, 235, 221, 0.1);
  border-radius: 22rpx;
  color: rgba(244, 235, 221, 0.74);
  background: rgba(255, 255, 255, 0.038);
}

.market-chip text,
.market-chip view {
  position: relative;
  z-index: 2;
  display: block;
}

.market-chip text {
  color: #fff6e6;
  font-size: 28rpx;
  font-weight: 900;
}

.market-chip view {
  margin-top: 8rpx;
  color: rgba(244, 235, 221, 0.54);
  font-size: 21rpx;
  line-height: 1.36;
}

.market-chip.active {
  border-color: rgba(216, 183, 111, 0.38);
  background: rgba(216, 183, 111, 0.1);
}

.timeframe-rail {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.timeframe-chip {
  min-width: 112rpx;
  height: 62rpx;
  padding: 0 18rpx;
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  border: 1rpx solid rgba(244, 235, 221, 0.1);
  border-radius: 999rpx;
  color: rgba(244, 235, 221, 0.7);
  background: rgba(255, 255, 255, 0.038);
  font-size: 24rpx;
  font-weight: 900;
}

.timeframe-chip.active {
  color: #14140f;
  border-color: rgba(216, 183, 111, 0.62);
  background: #d8b76f;
}

.mind-wave {
  margin-top: 24rpx;
  padding: 28rpx 24rpx 26rpx;
}

.wave-head {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}

.wave-head text:first-child {
  display: block;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 42rpx;
  line-height: 1.25;
}

.wave-head view view {
  margin-top: 10rpx;
  color: rgba(244, 235, 221, 0.58);
  font-size: 24rpx;
  line-height: 1.55;
}

.wave-head > text {
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 76rpx;
  display: grid;
  place-items: center;
  border-radius: 24rpx;
  color: #16160f;
  background:
    linear-gradient(180deg, rgba(255, 247, 207, 0.8), rgba(216, 183, 111, 0.92)),
    #d8b76f;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 38rpx;
  font-weight: 900;
}

.sim-meta {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 14rpx;
}

.sim-meta > view {
  min-height: 118rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.sim-meta text {
  display: block;
  color: rgba(216, 183, 111, 0.72);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.sim-meta view view {
  margin-top: 10rpx;
  color: rgba(244, 235, 221, 0.72);
  font-size: 24rpx;
  line-height: 1.48;
}

.wave-board {
  position: relative;
  z-index: 1;
  height: 312rpx;
  margin-top: 30rpx;
  padding: 22rpx 12rpx 16rpx;
  display: grid;
  grid-template-columns: repeat(14, 1fr);
  align-items: end;
  gap: 4rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(90deg, rgba(244, 235, 221, 0.035) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(244, 235, 221, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(244, 235, 221, 0.045), rgba(244, 235, 221, 0.018)),
    rgba(4, 8, 7, 0.46);
  background-size: 46rpx 100%, 100% 56rpx, 100% 100%, 100% 100%;
}

.wave-board::before {
  content: "";
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 50%;
  height: 1rpx;
  background: rgba(216, 183, 111, 0.12);
}

.mind-candle {
  position: relative;
  min-width: 0;
  height: 268rpx;
  display: block;
  color: rgba(244, 235, 221, 0.58);
  box-shadow: none;
  border-radius: 14rpx;
}

.mind-candle::before,
.mind-candle::after {
  display: none;
}

.mind-candle .wick {
  position: absolute;
  left: 50%;
  width: 4rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: rgba(244, 235, 221, 0.22);
}

.mind-candle .body {
  position: absolute;
  left: 50%;
  width: 18rpx;
  min-height: 18rpx;
  transform: translateX(-50%);
  border-radius: 4rpx;
  background: rgba(244, 235, 221, 0.2);
  box-shadow: 0 0 18rpx rgba(244, 235, 221, 0.08);
}

.mind-candle .volume {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 18rpx;
  transform: translateX(-50%);
  border-radius: 6rpx 6rpx 2rpx 2rpx;
  background: rgba(244, 235, 221, 0.12);
}

.mind-candle text {
  position: absolute;
  z-index: 3;
  left: 50%;
  top: 12rpx;
  width: 40rpx;
  height: 40rpx;
  display: grid;
  place-items: center;
  transform: translateX(-50%);
  border-radius: 50%;
  background: rgba(216, 183, 111, 0.22);
  color: rgba(244, 235, 221, 0.54);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 23rpx;
}

.mind-candle.gold .wick,
.mind-candle.gold .body,
.mind-candle.gold .volume {
  background: rgba(216, 183, 111, 0.72);
  box-shadow: 0 0 28rpx rgba(216, 183, 111, 0.18);
}

.mind-candle.jade .wick,
.mind-candle.jade .body,
.mind-candle.jade .volume {
  background: rgba(95, 132, 117, 0.76);
  box-shadow: 0 0 24rpx rgba(95, 132, 117, 0.16);
}

.mind-candle.ash .wick,
.mind-candle.ash .body,
.mind-candle.ash .volume {
  background: rgba(144, 132, 112, 0.58);
}

.mind-candle.flat .wick,
.mind-candle.flat .body,
.mind-candle.flat .volume {
  background: rgba(244, 235, 221, 0.24);
}

.mind-candle.focus text,
.mind-candle.selected text {
  color: #f6e0aa;
}

.mind-candle.selected .body {
  width: 24rpx;
  box-shadow:
    0 0 0 1rpx rgba(255, 246, 230, 0.18),
    0 0 34rpx rgba(216, 183, 111, 0.28);
}

.mind-candle.selected {
  background: linear-gradient(180deg, rgba(216, 183, 111, 0.1), transparent 70%);
}

.history-empty {
  position: relative;
  z-index: 1;
  min-height: 300rpx;
  margin-top: 30rpx;
  padding: 44rpx 34rpx;
  display: grid;
  align-content: center;
  border: 1rpx dashed rgba(216, 183, 111, 0.2);
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(244, 235, 221, 0.045), rgba(244, 235, 221, 0.018)),
    rgba(4, 8, 7, 0.46);
}

.history-empty view {
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 40rpx;
}

.history-empty text {
  display: block;
  margin-top: 16rpx;
  color: rgba(244, 235, 221, 0.58);
  font-size: 25rpx;
  line-height: 1.62;
}

.wave-question {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  padding: 24rpx;
  border-left: 4rpx solid rgba(216, 183, 111, 0.52);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.wave-question text {
  color: #d8b76f;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.wave-question .guardrail {
  margin-top: 16rpx;
  color: rgba(244, 235, 221, 0.46);
  font-size: 22rpx;
  line-height: 1.5;
  letter-spacing: 0;
}

.wave-question view {
  margin-top: 10rpx;
  color: rgba(255, 246, 230, 0.88);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 32rpx;
  line-height: 1.62;
}

.practice-card,
.method-card,
.prescription-card,
.gate-card,
.completion-card {
  margin-top: 28rpx;
  padding: 30rpx 28rpx;
}

.guide-toggle {
  margin-top: 22rpx;
}

.guide-toggle button {
  width: 100%;
}

.practice-title,
.method-title,
.prescription-title,
.gate-title {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 40rpx;
  line-height: 1.3;
}

.practice-flow {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.practice-flow text {
  min-height: 54rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: rgba(244, 235, 221, 0.64);
  border: 1rpx solid rgba(217, 189, 122, 0.12);
  background: rgba(255, 255, 255, 0.035);
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.08em;
}

.method-list {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: grid;
  gap: 16rpx;
}

.method-row {
  min-height: 150rpx;
  display: grid;
  grid-template-columns: 58rpx 1fr;
  gap: 18rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(244, 235, 221, 0.1);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.038);
}

.method-row.firecracker {
  border-color: rgba(216, 183, 111, 0.28);
  background:
    radial-gradient(circle at 18% 0%, rgba(216, 183, 111, 0.12), transparent 45%),
    rgba(255, 255, 255, 0.04);
}

.method-index {
  width: 58rpx;
  height: 58rpx;
  display: grid;
  place-items: center;
  border-radius: 18rpx;
  color: #15150f;
  background: rgba(216, 183, 111, 0.92);
  font-size: 24rpx;
  font-weight: 900;
}

.method-copy text {
  display: block;
  color: #fff6e6;
  font-size: 29rpx;
  font-weight: 900;
}

.method-copy > view {
  margin-top: 8rpx;
  color: rgba(244, 235, 221, 0.62);
  font-size: 24rpx;
  line-height: 1.5;
}

.method-copy .method-focus {
  color: rgba(216, 183, 111, 0.78);
  font-size: 23rpx;
  font-weight: 800;
}

.method-steps {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.method-steps text {
  min-height: 46rpx;
  padding: 0 16rpx;
  display: grid;
  place-items: center;
  border: 1rpx solid rgba(244, 235, 221, 0.1);
  border-radius: 999rpx;
  color: rgba(244, 235, 221, 0.68);
  background: rgba(5, 9, 8, 0.28);
  font-size: 21rpx;
  font-weight: 800;
}

.field-block {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
}

.compact-field {
  margin-top: 18rpx;
}

.field-mini-toggle {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
}

.field-mini-toggle button {
  width: 100%;
  min-height: 58rpx;
  font-size: 21rpx;
}

.option-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.option-grid.boundary {
  grid-template-columns: repeat(2, 1fr);
}

.option-pill {
  min-height: 76rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(244, 235, 221, 0.12);
  border-radius: 999rpx;
  color: rgba(244, 235, 221, 0.72);
  background: rgba(255, 255, 255, 0.04);
  font-size: 26rpx;
  font-weight: 800;
}

.option-pill text {
  position: relative;
  z-index: 2;
  color: inherit;
}

.option-pill.seal {
  min-height: 72rpx;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 31rpx;
}

.option-pill.active {
  color: #13140f;
  border-color: rgba(216, 183, 111, 0.75);
  background:
    linear-gradient(180deg, rgba(255, 247, 207, 0.72), rgba(216, 183, 111, 0.96)),
    #d8b76f;
}

.insight-textarea {
  width: 100%;
  min-height: 176rpx;
  margin-top: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(244, 235, 221, 0.12);
  border-radius: 20rpx;
  color: #fff6e6;
  background: rgba(5, 9, 8, 0.5);
  font-size: 28rpx;
  line-height: 1.58;
}

.save-btn {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
}

.completion-card {
  overflow: hidden;
  border-color: rgba(95, 132, 117, 0.24);
  background:
    radial-gradient(circle at 88% 0%, rgba(95, 132, 117, 0.14), transparent 42%),
    rgba(255, 255, 255, 0.035);
}

.completion-mark {
  width: 68rpx;
  height: 68rpx;
  display: grid;
  place-items: center;
  border-radius: 50%;
  color: rgba(255, 236, 205, 0.92);
  border: 2rpx solid rgba(154, 73, 48, 0.66);
  background: rgba(120, 60, 45, 0.32);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 32rpx;
  transform: rotate(-8deg);
}

.completion-card > view:nth-child(2) {
  margin-top: 18rpx;
}

.completion-card > view:nth-child(2) > text {
  display: block;
  color: rgba(244, 235, 221, 0.92);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.completion-card > view:nth-child(2) > view {
  margin-top: 8rpx;
  color: rgba(244, 235, 221, 0.62);
  font-size: 24rpx;
  line-height: 1.5;
}

.completion-card > text {
  display: block;
  margin-top: 16rpx;
  color: rgba(244, 235, 221, 0.48);
  font-size: 21rpx;
  line-height: 1.5;
}

.completion-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.path-links {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.prescription-grid {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: grid;
  gap: 16rpx;
}

.prescription-grid > view {
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.prescription-grid view view {
  margin-top: 10rpx;
  color: rgba(255, 246, 230, 0.8);
  font-size: 27rpx;
  line-height: 1.6;
}

.drill-card {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  padding: 24rpx;
  border-left: 4rpx solid rgba(95, 132, 117, 0.72);
  border-radius: 18rpx;
  background: rgba(95, 132, 117, 0.08);
}

.drill-card text {
  display: block;
  color: #86b4a1;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.drill-card view {
  margin-top: 10rpx;
  color: rgba(255, 246, 230, 0.78);
  font-size: 26rpx;
  line-height: 1.56;
}

.gate-list {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: grid;
  gap: 12rpx;
}

.gate-row {
  min-height: 106rpx;
  display: grid;
  grid-template-columns: 72rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 18rpx;
  border: 1rpx solid rgba(244, 235, 221, 0.1);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.032);
}

.gate-row.active {
  border-color: rgba(216, 183, 111, 0.34);
  background: rgba(216, 183, 111, 0.08);
}

.gate-seal {
  width: 72rpx;
  height: 72rpx;
  display: grid;
  place-items: center;
  border-radius: 22rpx;
  color: rgba(244, 235, 221, 0.68);
  border: 1rpx solid rgba(244, 235, 221, 0.12);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 34rpx;
}

.gate-row.active .gate-seal {
  color: #14140f;
  border-color: rgba(216, 183, 111, 0.5);
  background: #d8b76f;
}

.gate-row text {
  display: block;
  color: #fff6e6;
  font-size: 28rpx;
  font-weight: 900;
}

.gate-row view view {
  margin-top: 8rpx;
  color: rgba(244, 235, 221, 0.6);
  font-size: 24rpx;
  line-height: 1.48;
}

.gate-row view .gate-check {
  color: rgba(216, 183, 111, 0.72);
  font-size: 22rpx;
}

.completion-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.completion-card > view,
.completion-card > text {
  position: relative;
  z-index: 1;
}

.completion-card view view {
  margin-top: 8rpx;
  color: #f1d27d;
  font-size: 64rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.completion-card > text {
  flex: 1;
  color: rgba(244, 235, 221, 0.6);
  font-size: 24rpx;
  line-height: 1.55;
}

@media (max-width: 340px) {
  .hero-meta,
  .market-rail,
  .sim-meta,
  .option-grid {
    grid-template-columns: 1fr;
  }

  .option-grid.boundary {
    grid-template-columns: 1fr;
  }

  .kline-hero .page-title {
    font-size: 56rpx;
  }

  .completion-card {
    align-items: flex-start;
    flex-direction: column;
  }
}
