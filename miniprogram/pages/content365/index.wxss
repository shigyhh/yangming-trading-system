.content-card {
  margin-top: 34rpx;
  padding: 34rpx 30rpx;
}

.content-card > view {
  position: relative;
  z-index: 1;
}

.content-id {
  color: #b49355;
  font-family: "Inter", "ZX-Harmony", "HarmonyOS Sans SC", sans-serif;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.content-title {
  margin-top: 16rpx;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 52rpx;
  font-weight: 500;
}

.stage-pill {
  min-height: 52rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  color: #f6e0aa;
  border: 1rpx solid rgba(201, 157, 76, 0.34);
  background: rgba(201, 157, 76, 0.08);
  font-size: 22rpx;
  font-weight: 900;
}

.content-block {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.07);
}

.content-block text {
  display: block;
  color: #b49355;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.content-block view {
  margin-top: 12rpx;
  color: rgba(247, 239, 223, 0.84);
  font-size: 28rpx;
  line-height: 1.7;
}
