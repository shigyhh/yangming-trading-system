.hero-report {
  margin-top: 32rpx;
  padding: 40rpx 28rpx;
  display: grid;
  justify-items: center;
  text-align: center;
}

.ring,
.report-title,
.report-subtitle,
.secondary {
  position: relative;
  z-index: 1;
}

.ring {
  width: 188rpx;
  height: 188rpx;
  display: grid;
  place-items: center;
  align-content: center;
  border-radius: 50%;
  border: 2rpx solid rgba(201, 157, 76, 0.5);
  background: radial-gradient(circle, rgba(241, 210, 125, 0.14), rgba(255, 255, 255, 0.03) 64%);
}

.ring text {
  color: #f1d27d;
  font-family: "ZX-Harmony", "HarmonyOS Sans SC", "HarmonyOS Sans", -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
  font-size: 56rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.ring view {
  color: rgba(247, 239, 223, 0.55);
  font-size: 21rpx;
  font-weight: 800;
}

.report-title {
  margin-top: 28rpx;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 52rpx;
  font-weight: 900;
}

.report-subtitle {
  margin-top: 12rpx;
  color: #58c2ad;
  font-size: 27rpx;
  font-weight: 800;
  letter-spacing: 0.08em;
}

.secondary {
  margin-top: 16rpx;
  color: rgba(247, 239, 223, 0.58);
  font-size: 24rpx;
}

.binding-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.binding-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.binding-head view text {
  display: block;
  color: #f1d27d;
  font-size: 23rpx;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.binding-head view view {
  margin-top: 10rpx;
  color: #fff6e6;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 800;
}

.binding-head > text {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #58c2ad;
  border: 1rpx solid rgba(88, 194, 173, 0.22);
  background: rgba(88, 194, 173, 0.06);
  font-size: 21rpx;
  font-weight: 900;
}

.binding-grid {
  margin-top: 22rpx;
  display: grid;
  gap: 12rpx;
}

.binding-grid > view {
  min-height: 82rpx;
  padding: 16rpx 18rpx;
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 18rpx;
  align-items: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.binding-grid text {
  color: #b49355;
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.binding-grid view view {
  color: rgba(247, 239, 223, 0.78);
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 800;
}

.binding-note {
  margin-top: 18rpx;
  color: rgba(247, 239, 223, 0.5);
  font-size: 23rpx;
  line-height: 1.58;
}

.mini-report-card,
.risk-card,
.persona-brief,
.danger-card,
.mode-lines-card,
.evidence-card,
.kline-change-card,
.retest-change-card,
.compliance-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.mini-report-card > text,
.risk-card > text,
.danger-card > text,
.mode-lines-card > text,
.evidence-card > text,
.kline-change-card > text,
.retest-change-card > text {
  position: relative;
  z-index: 1;
  display: block;
  color: #f1d27d;
  font-size: 23rpx;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.mini-report-card > view {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  color: rgba(247, 239, 223, 0.78);
  font-size: 28rpx;
  line-height: 1.62;
}

.evidence-mantra {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-left: 4rpx solid rgba(88, 194, 173, 0.75);
  color: rgba(247, 239, 223, 0.7);
  background: rgba(88, 194, 173, 0.07);
  font-size: 24rpx;
  line-height: 1.55;
}

.evidence-row {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 86rpx 1fr;
  gap: 18rpx;
  align-items: start;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.evidence-weight {
  min-height: 52rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: #11140f;
  background: linear-gradient(180deg, #f1d27d, #c99d4c);
  font-size: 23rpx;
  font-weight: 900;
}

.evidence-row text {
  color: #fff6e6;
  font-size: 25rpx;
  font-weight: 900;
}

.evidence-row view view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.62);
  font-size: 23rpx;
  line-height: 1.55;
}

.kline-change-meta {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  color: rgba(247, 239, 223, 0.64);
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 800;
}

.persona-brief {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.persona-brief > view {
  position: relative;
  z-index: 1;
  min-height: 132rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.persona-brief text {
  display: block;
  color: #b49355;
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.persona-brief view view {
  margin-top: 12rpx;
  color: #fff6e6;
  font-size: 32rpx;
  font-weight: 900;
}

.risk-grid {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.danger-card {
  padding: 28rpx;
}

.danger-card > view,
.mode-lines-card > view {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 54rpx 1fr;
  gap: 16rpx;
  align-items: start;
}

.danger-card > view > text,
.mode-lines-card > view > text {
  width: 44rpx;
  height: 44rpx;
  display: grid;
  place-items: center;
  border-radius: 50%;
  color: #11140f;
  background: linear-gradient(180deg, #f1d27d, #c99d4c);
  font-size: 22rpx;
  font-weight: 900;
}

.danger-card > view > view,
.mode-lines-card > view > view {
  color: rgba(247, 239, 223, 0.76);
  font-size: 26rpx;
  line-height: 1.55;
  font-weight: 800;
}

.retest-metrics {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  display: grid;
  gap: 12rpx;
}

.retest-metrics > view {
  min-height: 78rpx;
  padding: 16rpx 18rpx;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.retest-metrics text {
  color: rgba(247, 239, 223, 0.72);
  font-size: 25rpx;
  font-weight: 800;
}

.retest-metrics view view {
  color: #58c2ad;
  font-size: 25rpx;
  font-weight: 900;
}

.kline-before-after {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: grid;
  gap: 10rpx;
}

.kline-before-after > view {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(247, 239, 223, 0.08);
}

.kline-before-after text {
  color: rgba(247, 239, 223, 0.62);
  font-size: 23rpx;
  font-weight: 800;
}

.kline-before-after view view {
  color: #f1d27d;
  font-size: 23rpx;
  font-weight: 900;
}

.risk-grid > view {
  min-height: 158rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.risk-row-head {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.risk-row-head text:first-child {
  color: #b49355;
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.risk-row-head text:last-child {
  color: #f1d27d;
  font-size: 30rpx;
  font-weight: 900;
}

.risk-bar {
  height: 10rpx;
  margin-top: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.risk-bar view {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #58c2ad, #f1d27d);
}

.risk-level {
  margin-top: 12rpx;
  color: #fff6e6;
  font-size: 24rpx;
  font-weight: 900;
}

.risk-desc {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.52);
  font-size: 21rpx;
  line-height: 1.45;
}

.compliance-card {
  color: rgba(247, 239, 223, 0.52);
  font-size: 23rpx;
  line-height: 1.6;
}

.report-list {
  display: grid;
  gap: 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.07);
}

.report-block {
  padding: 30rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
}

.report-block text,
.report-block view,
.path-card text,
.path-row {
  position: relative;
  z-index: 1;
}

@media (max-width: 340px) {
  .ring {
    width: 168rpx;
    height: 168rpx;
  }

  .report-title {
    font-size: 48rpx;
  }

  .path-row {
    gap: 10rpx;
  }

  .path-step {
    min-height: 126rpx;
  }

  .binding-grid > view {
    grid-template-columns: 1fr;
  }

  .persona-brief,
  .risk-grid {
    grid-template-columns: 1fr;
  }
}

.report-block text,
.path-card > text {
  color: #f1d27d;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0.12em;
}

.report-block view {
  margin-top: 14rpx;
  color: rgba(247, 239, 223, 0.78);
  font-size: 28rpx;
  line-height: 1.62;
}

.path-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.stage-path-card {
  margin-top: 24rpx;
  padding: 30rpx 28rpx;
}

.core-output-card {
  margin-top: 22rpx;
  padding: 8rpx 28rpx;
}

.stage-path-card text,
.stage-path-card view,
.core-output-row text,
.core-output-row view {
  position: relative;
  z-index: 1;
}

.stage-path-card > text {
  color: #f1d27d;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.path-focus {
  margin-top: 18rpx;
  color: #fff6e6;
  font-family: "Source Han Serif SC", "Noto Serif CJK SC", "Songti SC", "STSong", serif;
  font-size: 42rpx;
  font-weight: 800;
}

.path-copy {
  margin-top: 14rpx;
  color: rgba(247, 239, 223, 0.78);
  font-size: 27rpx;
  line-height: 1.62;
}

.muted-copy {
  color: rgba(247, 239, 223, 0.56);
}

.core-output-row {
  min-height: 104rpx;
  display: grid;
  grid-template-columns: 180rpx 1fr;
  align-items: center;
  gap: 22rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
}

.core-output-row:last-child {
  border-bottom: 0;
}

.core-output-row text {
  color: #b49355;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.core-output-row view {
  color: #fff6e6;
  font-size: 28rpx;
  line-height: 1.52;
  font-weight: 800;
}

.path-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.path-step {
  min-height: 136rpx;
  padding: 20rpx 10rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 10rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.045);
}

.path-step view {
  width: 42rpx;
  height: 42rpx;
  display: grid;
  place-items: center;
  border-radius: 50%;
  color: #11140f;
  background: #f1d27d;
  font-size: 22rpx;
  font-weight: 900;
}

.path-step text {
  color: #fff6e6;
  font-size: 24rpx;
  text-align: center;
}

.empty-report {
  margin-top: 34rpx;
  padding: 34rpx;
}

.empty-report view,
.empty-report text,
.empty-report button {
  position: relative;
  z-index: 1;
}

.empty-report view {
  color: #fff6e6;
  font-family: "Source Han Serif SC", "Noto Serif CJK SC", "Songti SC", "STSong", serif;
  font-size: 42rpx;
  font-weight: 700;
}

.empty-report text {
  display: block;
  margin: 18rpx 0 28rpx;
  color: rgba(247, 239, 223, 0.62);
  font-size: 26rpx;
  line-height: 1.62;
}
