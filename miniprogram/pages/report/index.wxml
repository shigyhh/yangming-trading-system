<view class="page-shell">
  <view class="page-content">
    <text class="eyebrow">PERSONALITY · 观心</text>
    <view class="page-title">九型人格<br />心证</view>
    <view class="page-subtitle">不是评判你，而是照见惯性动作，把它转成每日修行。</view>

    <block wx:if="{{hasResult}}">
      <view class="hero-report card">
        <view class="ring">
          <text>{{result.intensity}}</text>
          <view>显现度</view>
        </view>
        <view class="report-title">{{result.primary}}</view>
        <view class="report-subtitle">{{stagePlan.stageName}}</view>
        <view class="secondary">次人格：{{result.secondary}}</view>
      </view>

      <view class="binding-card card">
        <view class="binding-head">
          <view>
            <text>手机号贯穿档案</text>
            <view>{{userBinding.phoneMask}} · {{userBinding.phoneBound ? '已绑定' : '待绑定'}}</view>
          </view>
          <text>{{assessmentHistory.length || 1}}次照见</text>
        </view>
        <view class="binding-grid">
          <view>
            <text>网站测评报告</text>
            <view>{{result.primary}}</view>
          </view>
          <view>
            <text>复测变化</text>
            <view>{{retestChange.title}}</view>
          </view>
          <view>
            <text>邀请码来源</text>
            <view>{{userBinding.inviteSource || '自然进入'}}</view>
          </view>
        </view>
        <view class="binding-note">{{retestChange.detail}}</view>
      </view>

      <view wx:if="{{retestChange.metrics.length}}" class="retest-change-card card">
        <text>复测变化</text>
        <view class="retest-metrics">
          <view wx:for="{{retestChange.metrics}}" wx:key="label">
            <text>{{item.label}}</text>
            <view>{{item.value}}</view>
          </view>
        </view>
      </view>

      <view class="kline-change-card card">
        <text>{{klineChange.title}}</text>
        <view class="kline-change-meta">{{klineChange.fromSegment}} → {{klineChange.toSegment}}</view>
        <view class="kline-change-meta">{{klineChange.fromMirror}} → {{klineChange.toMirror}}</view>
        <view class="retest-metrics">
          <view wx:for="{{klineChange.metrics}}" wx:key="key">
            <text>{{item.label}}</text>
            <view>{{item.value}}</view>
          </view>
        </view>
        <view class="kline-before-after">
          <view wx:for="{{klineChange.beforeAfterRows}}" wx:key="key">
            <text>{{item.label}}</text>
            <view>{{item.before}} → {{item.after}}</view>
          </view>
        </view>
        <view class="binding-note">{{klineChange.insight}}</view>
      </view>

      <view class="kline-change-card card">
        <text>{{klineDayRetest.title}}</text>
        <view class="kline-change-meta">{{klineDayRetest.stageText}}</view>
        <view class="kline-change-meta">{{klineDayRetest.mirrorLine}}</view>
        <view class="retest-metrics">
          <view wx:for="{{klineDayRetest.metrics}}" wx:key="key">
            <text>{{item.label}}</text>
            <view>{{item.value}}</view>
          </view>
        </view>
        <view class="binding-note">{{klineDayRetest.insight}}</view>
      </view>

      <view class="mini-report-card card">
        <text>一句话照见</text>
        <view>{{miniReport.oneLine}}</view>
      </view>

      <view class="persona-brief card">
        <view>
          <text>主人格</text>
          <view>{{miniReport.primary}}</view>
        </view>
        <view>
          <text>副人格</text>
          <view>{{miniReport.secondary}}</view>
        </view>
        <view>
          <text>主镜</text>
          <view>{{miniReport.primaryMirror}}</view>
        </view>
        <view>
          <text>心贼</text>
          <view>{{miniReport.heartThievesText}}</view>
        </view>
      </view>

      <view class="kline-prescription-card card">
        <text>专属 K线处方</text>
        <view class="kline-prescription-title">{{klineRecommendation.title}}</view>
        <view class="kline-prescription-reason">{{klineRecommendation.reason}}</view>
        <view class="kline-prescription-meta">{{klineRecommendation.marketLabel}} · {{klineRecommendation.timeframeLabel}} · Day {{klineRecommendation.trainingDay}}</view>
        <button class="primary-btn" bindtap="goKlineSimulator">{{klineRecommendation.actionText}}</button>
      </view>

      <view class="mini-report-card card">
        <text>九镜与六贼</text>
        <view>{{miniReport.mirrorLine}}</view>
      </view>

      <view class="evidence-card card">
        <text>行为证据链</text>
        <view class="evidence-mantra">问卷照见倾向，K线照见反应，复盘照见模式，训练照见变化。</view>
        <view wx:for="{{evidenceChain}}" wx:key="source" class="evidence-row">
          <view class="evidence-weight">{{item.weight}}</view>
          <view>
            <text>{{item.source}} · {{item.title}}</text>
            <view>{{item.detail}}</view>
          </view>
        </view>
      </view>

      <view class="risk-card card">
        <text>风险雷达</text>
        <view class="risk-grid">
          <view wx:for="{{miniReport.radar}}" wx:key="key">
            <view class="risk-row-head">
              <text>{{item.label}}</text>
              <text>{{item.displayValue}}</text>
            </view>
            <view class="risk-bar"><view style="width: {{item.value}}%;"></view></view>
            <view class="risk-level">{{item.level}}</view>
            <view class="risk-desc">{{item.description}}</view>
          </view>
        </view>
      </view>

      <view class="mini-report-card card">
        <text>情绪触发</text>
        <view>{{miniReport.trigger}}</view>
      </view>

      <view class="mode-lines-card card">
        <text>核心交易模式</text>
        <view wx:for="{{miniReport.modeLines}}" wx:key="*this">
          <text>{{index + 1}}</text>
          <view>{{item}}</view>
        </view>
      </view>

      <view class="danger-card card">
        <text>最需照见的场景</text>
        <view wx:for="{{miniReport.dangerScenarios}}" wx:key="*this">
          <text>{{index + 1}}</text>
          <view>{{item}}</view>
        </view>
      </view>

      <view class="path-card card">
        <text>7 天训练处方</text>
        <view class="path-row">
          <view wx:for="{{miniReport.prescription}}" wx:key="day" class="path-step">
            <view>{{item.day}}</view>
            <text>{{item.title}}</text>
          </view>
        </view>
      </view>

      <view class="mini-report-card card">
        <text>今日训练</text>
        <view>{{miniReport.todayAction}}</view>
      </view>

      <view class="mini-report-card card">
        <text>K线校准</text>
        <view>{{miniReport.klineCalibration}}</view>
      </view>

      <view class="compliance-card card">{{miniReport.compliance}}</view>

      <view class="split-actions">
        <button class="secondary-btn" bindtap="saveReport">收藏心证</button>
        <button class="primary-btn" bindtap="goTraining">开始事上练</button>
      </view>
      <view class="single-action">
        <button class="primary-btn" bindtap="goKlineSimulator">进入 K线压力测试</button>
      </view>
      <view class="single-action">
        <button class="ghost-btn" bindtap="goTradeReview">上传真实记录复盘</button>
      </view>
      <view class="split-actions">
        <button class="ghost-btn" data-type="personality" bindtap="goShareCard">生成人格照见卡</button>
        <button class="ghost-btn" data-type="risk_radar" bindtap="goShareCard">生成风险雷达卡</button>
      </view>
      <view class="split-actions">
        <button class="ghost-btn" data-type="personality_mirror" bindtap="goShareCard">生成同修镜像卡</button>
        <button class="ghost-btn" data-type="group_practice" bindtap="goShareCard">生成共修邀请卡</button>
      </view>
      <view class="split-actions">
        <button class="ghost-btn" bindtap="goAssessment">重新照见</button>
        <button class="ghost-btn" bindtap="goStages">看六大关卡</button>
      </view>
      <view class="single-action">
        <button class="ghost-btn" bindtap="goIndex">看知行指数</button>
      </view>
    </block>

    <view wx:else class="empty-report card">
      <view>还没有人格心证</view>
      <text>先完成九型人格照见，再生成专属事上练路径。</text>
      <button class="primary-btn" bindtap="goAssessment">开始照见</button>
    </view>

    <compliance-notice />
  </view>
  <bottom-tab-bar active="assessment" />
</view>
