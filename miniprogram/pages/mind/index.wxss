.mind-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: calc(48rpx + env(safe-area-inset-top)) 48rpx calc(220rpx + env(safe-area-inset-bottom));
  color: #f7efdf;
  background:
    radial-gradient(circle at 72% 6%, rgba(211, 168, 79, 0.14), transparent 28%),
    linear-gradient(180deg, #0b1118 0%, #070d11 45%, #030606 100%);
  font-family: "ZX-Harmony", "HarmonyOS Sans SC", "HarmonyOS Sans", -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

.mind-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.mist {
  opacity: 0.7;
  background:
    radial-gradient(ellipse at 50% 20%, rgba(255, 246, 226, 0.06), transparent 42%),
    linear-gradient(110deg, transparent 12%, rgba(255, 255, 255, 0.026) 42%, transparent 72%);
}

.grain {
  opacity: 0.09;
  background:
    linear-gradient(90deg, rgba(241, 210, 125, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(241, 210, 125, 0.035) 1rpx, transparent 1rpx);
  background-size: 92rpx 92rpx;
  animation: grainDrift 24s linear infinite;
}

.halo {
  top: -20%;
  left: 18%;
  right: auto;
  bottom: auto;
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  opacity: 0.18;
  background: radial-gradient(circle, rgba(241, 210, 125, 0.22), transparent 64%);
  animation: breath 7s ease-in-out infinite;
}

.mind-content {
  position: relative;
  z-index: 2;
  animation: riseIn 0.78s cubic-bezier(0.19, 1, 0.22, 1) both;
}

.mind-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.seal {
  width: 82rpx;
  height: 82rpx;
  display: grid;
  place-items: center;
  border-radius: 24rpx;
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.36);
  background: rgba(255, 255, 255, 0.045);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 900;
}

.mind-head text {
  color: #fff7e7;
  font-size: 30rpx;
  font-weight: 900;
}

.mind-head view view {
  margin-top: 8rpx;
  color: rgba(241, 210, 125, 0.48);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0.16em;
}

.hero {
  margin-top: 78rpx;
}

.hero text {
  color: rgba(241, 210, 125, 0.54);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.28em;
}

.hero view {
  margin-top: 20rpx;
  color: #fff7e7;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.18;
}

.mind-instrument {
  position: relative;
  width: 100%;
  min-height: 0;
  margin-top: 56rpx;
  padding: 28rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  overflow: visible;
  border-radius: 44rpx;
  background:
    radial-gradient(circle at 50% 52%, rgba(241, 210, 125, 0.11), transparent 30%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.048), rgba(255, 255, 255, 0.014)),
    rgba(8, 13, 12, 0.46);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.07),
    0 34rpx 90rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(28rpx);
}

.instrument-line {
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(241, 210, 125, 0.68), transparent);
  animation: threadFlow 5s ease-in-out infinite;
}

.instrument-status {
  position: relative;
  left: auto;
  top: auto;
  right: auto;
  z-index: 6;
  grid-column: 1 / -1;
  order: 0;
  min-height: 54rpx;
  margin-bottom: 10rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: rgba(247, 239, 223, 0.48);
}

.instrument-status text {
  color: rgba(241, 210, 125, 0.58);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.22em;
}

.instrument-status view {
  font-size: 21rpx;
  font-weight: 800;
}

.ring {
  display: none;
}

.ring-a {
  width: 500rpx;
  height: 500rpx;
  animation: slowSpin 28s linear infinite;
}

.ring-b {
  width: 380rpx;
  height: 380rpx;
  border-style: dashed;
  opacity: 0.8;
  animation: slowSpinReverse 36s linear infinite;
}

.ring-c {
  width: 240rpx;
  height: 240rpx;
  opacity: 0.6;
  animation: breath 6.8s ease-in-out infinite;
}

.instrument-core {
  position: relative;
  left: auto;
  top: auto;
  z-index: 5;
  grid-column: 1 / -1;
  order: 1;
  width: 100%;
  height: auto;
  min-height: 210rpx;
  margin-bottom: 8rpx;
  padding: 30rpx 28rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  border-radius: 32rpx;
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.4);
  background:
    radial-gradient(circle at 50% 40%, rgba(241, 210, 125, 0.18), transparent 42%),
    rgba(255, 255, 255, 0.022);
  box-shadow:
    inset 0 0 46rpx rgba(241, 210, 125, 0.08),
    0 0 82rpx rgba(241, 210, 125, 0.08);
  transform: none;
}

.core-glow {
  position: absolute;
  inset: -40rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(241, 210, 125, 0.12), transparent 68%);
  animation: breath 5.8s ease-in-out infinite;
}

.core-glyph {
  position: relative;
  z-index: 1;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 64rpx;
  font-weight: 900;
}

.core-name {
  position: relative;
  z-index: 1;
  margin-top: 2rpx;
  color: #fff7e7;
  font-size: 28rpx;
  font-weight: 900;
}

.core-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 6rpx;
  color: rgba(247, 239, 223, 0.5);
  font-size: 23rpx;
}

.wave {
  position: relative;
  z-index: 1;
  height: 54rpx;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.wave view {
  width: 7rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(246, 216, 134, 0.96), rgba(84, 176, 158, 0.64));
  animation: waveBreath 1.8s ease-in-out infinite;
}

.wave view:nth-child(2n) {
  animation-delay: 0.24s;
}

.wave view:nth-child(3n) {
  animation-delay: 0.42s;
}

.orbit-node {
  position: relative;
  z-index: 7;
  order: 2;
  width: 100%;
  height: 104rpx;
  display: grid;
  place-items: center;
  align-content: center;
  border-radius: 26rpx;
  color: rgba(247, 239, 223, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  background: rgba(255, 255, 255, 0.032);
  backdrop-filter: blur(16rpx);
}

.orbit-node text {
  color: currentColor;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 34rpx;
  font-weight: 900;
}

.orbit-node view {
  margin-top: 4rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.orbit-node.active {
  color: #f6d886;
  border-color: rgba(241, 210, 125, 0.36);
  background: rgba(201, 157, 76, 0.1);
  box-shadow:
    0 0 34rpx rgba(201, 157, 76, 0.12),
    inset 0 0 18rpx rgba(241, 210, 125, 0.08);
}

.node-0,
.node-1,
.node-2,
.node-3,
.node-4,
.node-5,
.node-6,
.node-7 {
  left: auto;
  right: auto;
  top: auto;
  bottom: auto;
  transform: none;
}

.breath-panel {
  margin-top: 30rpx;
  padding: 26rpx;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 22rpx;
  align-items: center;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.028);
  border: 1rpx solid rgba(241, 210, 125, 0.12);
}

.breath-panel > view:first-child text {
  display: block;
  color: rgba(241, 210, 125, 0.62);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.breath-panel > view:first-child view {
  margin-top: 10rpx;
  color: #fff7e7;
  font-size: 30rpx;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-weight: 900;
}

.breath-dots {
  display: flex;
  gap: 10rpx;
}

.breath-dots i {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.breath-dots i.active {
  background: #f6d886;
  box-shadow: 0 0 24rpx rgba(241, 210, 125, 0.32);
}

.breath-panel button {
  grid-column: 1 / -1;
  height: 78rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.24);
  background: rgba(201, 157, 76, 0.06);
  font-size: 26rpx;
  font-weight: 900;
}

.opening-form {
  margin-top: 30rpx;
  display: grid;
  gap: 18rpx;
}

.opening-section {
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(241, 210, 125, 0.12);
  background: rgba(255, 255, 255, 0.028);
}

.opening-section > text {
  display: block;
  color: rgba(241, 210, 125, 0.66);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.opening-section > view {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.opening-section button {
  min-height: 58rpx;
  padding: 0 20rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: rgba(247, 239, 223, 0.6);
  border: 1rpx solid rgba(241, 210, 125, 0.12);
  background: rgba(255, 255, 255, 0.026);
  font-size: 23rpx;
  font-weight: 800;
}

.opening-section button.active {
  color: #11130d;
  background: linear-gradient(180deg, rgba(240, 211, 118, 0.92), rgba(188, 137, 52, 0.88));
}

.note-section textarea {
  width: 100%;
  min-height: 132rpx;
  margin-top: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  color: #f7efdf;
  border: 1rpx solid rgba(241, 210, 125, 0.12);
  background: rgba(0, 0, 0, 0.16);
  font-size: 25rpx;
  line-height: 1.6;
}

.opening-placeholder {
  color: rgba(247, 239, 223, 0.34);
}

.ritual-scroll {
  position: relative;
  margin-top: 46rpx;
  padding: 42rpx 30rpx 38rpx;
  overflow: hidden;
  border-radius: 38rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.052), rgba(255, 255, 255, 0.016)),
    rgba(8, 13, 12, 0.58);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.07),
    0 30rpx 80rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(28rpx);
}

.scroll-line {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(241, 210, 125, 0.68), transparent);
  animation: threadFlow 5s ease-in-out infinite;
}

.ritual-glyph {
  display: none;
}

.ritual-title {
  color: #fff7e7;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 46rpx;
  font-weight: 900;
}

.ritual-subtitle {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.5);
  font-size: 24rpx;
}

.ritual-list {
  margin-top: 36rpx;
  display: grid;
  gap: 24rpx;
}

.ritual-item {
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.065);
}

.ritual-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.ritual-item text {
  display: block;
  color: rgba(241, 210, 125, 0.6);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.ritual-item view {
  margin-top: 12rpx;
  color: rgba(247, 239, 223, 0.72);
  font-size: 27rpx;
  line-height: 1.7;
}

.ritual-item.main view {
  color: #fff7e7;
  font-size: 32rpx;
  font-weight: 900;
}

.loop-strip {
  margin-top: 34rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.loop-strip button {
  min-width: 0;
  min-height: 64rpx;
  padding: 0 12rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: rgba(247, 239, 223, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.075);
  background: rgba(255, 255, 255, 0.026);
  font-size: 22rpx;
  font-weight: 800;
}

.loop-strip button::before,
.loop-strip button::after {
  display: none;
}

.loop-strip button.current {
  color: #11130d;
  background: linear-gradient(180deg, #f6d886, #c99d4c);
}

.loop-strip button text {
  position: relative;
  z-index: 2;
}

.actions {
  margin-top: 38rpx;
  display: grid;
  grid-template-columns: 0.82fr 1.18fr;
  gap: 16rpx;
}

.secondary,
.primary {
  height: 88rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.secondary {
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.28);
  background: rgba(201, 157, 76, 0.06);
}

.primary {
  color: #11130d;
  background: linear-gradient(105deg, rgba(255, 245, 205, 0.96), rgba(227, 181, 82, 0.96), rgba(255, 238, 181, 0.96));
  background-size: 200% 100%;
  box-shadow: 0 24rpx 54rpx rgba(201, 157, 76, 0.22);
  animation: buttonGoldFlow 5.4s ease-in-out infinite;
}

.review-link {
  margin-top: 28rpx;
  color: rgba(247, 239, 223, 0.42);
  font-size: 23rpx;
  text-align: center;
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(32rpx) scale(0.985);
    filter: blur(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes grainDrift {
  from { background-position: 0 0; }
  to { background-position: 92rpx 184rpx; }
}

@keyframes breath {
  0%, 100% {
    opacity: 0.14;
    transform: scale(0.96);
  }
  50% {
    opacity: 0.28;
    transform: scale(1.06);
  }
}

@keyframes threadFlow {
  0%, 100% {
    opacity: 0.28;
    transform: scaleX(0.76);
  }
  50% {
    opacity: 0.9;
    transform: scaleX(1);
  }
}

@keyframes buttonGoldFlow {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@media (max-width: 340px) {
  .mind-shell {
    padding-left: 42rpx;
    padding-right: 42rpx;
  }

  .mind-instrument {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding: 24rpx;
  }

  .instrument-core {
    width: 100%;
    height: auto;
    min-height: 190rpx;
  }

  .orbit-node {
    width: 100%;
    height: 90rpx;
    border-radius: 26rpx;
  }

  .orbit-node text {
    font-size: 34rpx;
  }

  .orbit-node view {
    font-size: 17rpx;
  }

  .actions {
    grid-template-columns: 1fr;
  }
}
