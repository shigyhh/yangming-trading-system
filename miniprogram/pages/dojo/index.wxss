.dojo-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: calc(48rpx + env(safe-area-inset-top)) 48rpx calc(220rpx + env(safe-area-inset-bottom));
  color: #f7efdf;
  background:
    radial-gradient(circle at 74% 6%, rgba(211, 168, 79, 0.14), transparent 30%),
    radial-gradient(circle at 18% 20%, rgba(88, 194, 173, 0.1), transparent 32%),
    linear-gradient(180deg, #081014 0%, #07100f 52%, #030606 100%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", "Microsoft YaHei", sans-serif;
}

.dojo-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.mist {
  opacity: 0.64;
  background:
    radial-gradient(ellipse at 50% 16%, rgba(255, 246, 226, 0.052), transparent 42%),
    linear-gradient(112deg, transparent 12%, rgba(255, 255, 255, 0.026) 46%, transparent 78%);
}

.grain {
  opacity: 0.08;
  background:
    linear-gradient(90deg, rgba(241, 210, 125, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(241, 210, 125, 0.035) 1rpx, transparent 1rpx);
  background-size: 92rpx 92rpx;
  animation: grainDrift 24s linear infinite;
}

.dojo-content {
  position: relative;
  z-index: 2;
  animation: riseIn 0.78s cubic-bezier(0.19, 1, 0.22, 1) both;
}

.head {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.seal {
  width: 82rpx;
  height: 82rpx;
  display: grid;
  place-items: center;
  border-radius: 24rpx;
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.36);
  background: rgba(255, 255, 255, 0.045);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 900;
}

.head text {
  color: #fff7e7;
  font-size: 30rpx;
  font-weight: 900;
}

.head view view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.46);
  font-size: 22rpx;
}

.dojo-hero,
.reflection-wall,
.tribe-card,
.mentor-card,
.task-card,
.handoff-card,
.assistant-card,
.archive-card,
.leaderboard-card,
.story-card,
.records-card,
.milestone-card {
  position: relative;
  margin-top: 28rpx;
  padding: 28rpx;
  overflow: hidden;
  border-radius: 30rpx;
  border: 1rpx solid rgba(241, 210, 125, 0.16);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.052), rgba(255, 255, 255, 0.016)),
    rgba(8, 13, 12, 0.52);
}

.gold-thread {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(241, 210, 125, 0.68), transparent);
  animation: threadFlow 4.8s ease-in-out infinite;
}

.dojo-hero > text {
  display: block;
  color: #58c2ad;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.dojo-hero > view:last-of-type {
  margin-top: 12rpx;
  color: #fff7e7;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 900;
}

.dojo-subcopy {
  margin-top: 14rpx !important;
  color: rgba(247, 239, 223, 0.52) !important;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", "Microsoft YaHei", sans-serif !important;
  font-size: 24rpx !important;
  line-height: 1.55;
}

.dojo-hero button,
.dojo-primary,
.dojo-secondary,
.dojo-ghost,
.growth-link {
  width: 100%;
  height: 84rpx;
  margin-top: 22rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.companion-stats {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.companion-stats > view {
  min-height: 112rpx;
  padding: 18rpx 10rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  border-radius: 22rpx;
  border: 1rpx solid rgba(241, 210, 125, 0.12);
  background: rgba(255, 255, 255, 0.035);
}

.companion-stats text {
  color: #f6d886;
  font-size: 32rpx;
  font-weight: 900;
}

.companion-stats view view {
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.48);
  font-size: 20rpx;
  text-align: center;
}

.dojo-hero button,
.dojo-primary {
  color: #11130d;
  background: linear-gradient(105deg, rgba(255, 245, 205, 0.96), rgba(227, 181, 82, 0.96), rgba(255, 238, 181, 0.96));
}

.dojo-secondary {
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.3);
  background: rgba(201, 157, 76, 0.08);
}

.dojo-ghost,
.growth-link {
  color: rgba(247, 239, 223, 0.82);
  border: 1rpx solid rgba(247, 239, 223, 0.14);
  background: rgba(255, 255, 255, 0.045);
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.card-head view text {
  display: block;
  color: #58c2ad;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.card-head view view {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.68);
  font-size: 25rpx;
  line-height: 1.45;
}

.card-head > text {
  min-width: 78rpx;
  height: 48rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: #f6d886;
  border: 1rpx solid rgba(241, 210, 125, 0.22);
  font-size: 21rpx;
  font-weight: 900;
}

.dojo-input,
.dojo-textarea {
  width: 100%;
  margin-top: 22rpx;
  border: 1rpx solid rgba(241, 210, 125, 0.16);
  border-radius: 20rpx;
  color: #fff7e7;
  background: rgba(255, 255, 255, 0.045);
  font-size: 27rpx;
}

.mentor-note,
.mentor-scope,
.mentor-privacy {
  margin-top: 16rpx;
  color: rgba(247, 239, 223, 0.52);
  font-size: 23rpx;
  line-height: 1.55;
}

.human-mentor {
  margin-top: 22rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
}

.human-mentor view text {
  display: block;
  color: #f6d886;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.human-mentor view view {
  margin-top: 8rpx;
  color: #fff7e7;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.4;
}

.human-mentor > text {
  flex: 0 0 auto;
  color: rgba(247, 239, 223, 0.46);
  font-size: 22rpx;
  font-weight: 900;
}

.role-switch {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.role-switch button {
  height: 70rpx;
  display: grid;
  place-items: center;
  border-radius: 999rpx;
  color: rgba(247, 239, 223, 0.66);
  border: 1rpx solid rgba(247, 239, 223, 0.12);
  background: rgba(255, 255, 255, 0.04);
  font-size: 24rpx;
  font-weight: 900;
}

.role-switch button.active {
  color: #11130d;
  border-color: rgba(241, 210, 125, 0.74);
  background: linear-gradient(105deg, rgba(255, 245, 205, 0.96), rgba(227, 181, 82, 0.96));
}

.dojo-input {
  height: 82rpx;
  padding: 0 22rpx;
}

.dojo-textarea {
  min-height: 150rpx;
  padding: 22rpx;
  line-height: 1.55;
}

.discipline {
  margin-top: 22rpx;
  color: #f6d886;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 36rpx;
  line-height: 1.4;
  font-weight: 900;
}

.task-action {
  margin-top: 14rpx;
  color: rgba(247, 239, 223, 0.62);
  font-size: 26rpx;
  line-height: 1.62;
}

.task-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.handoff-summary {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  color: #fff7e7;
  background: rgba(201, 157, 76, 0.08);
  font-size: 25rpx;
  line-height: 1.58;
  font-weight: 800;
}

.handoff-grid {
  margin-top: 18rpx;
  display: grid;
  gap: 10rpx;
}

.handoff-row {
  min-height: 76rpx;
  padding: 16rpx 18rpx;
  display: grid;
  grid-template-columns: 140rpx 1fr;
  gap: 18rpx;
  align-items: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.036);
}

.handoff-row text {
  color: #b49355;
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.handoff-row view {
  color: rgba(247, 239, 223, 0.78);
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 800;
}

.assistant-reply {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(88, 194, 173, 0.08);
}

.assistant-reply text {
  display: block;
  color: #58c2ad;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.assistant-reply view {
  margin-top: 12rpx;
  color: rgba(247, 239, 223, 0.76);
  font-size: 26rpx;
  line-height: 1.6;
}

.archive-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.archive-card view text {
  color: #f6d886;
  font-size: 28rpx;
  font-weight: 900;
}

.archive-card view view {
  margin-top: 10rpx;
  color: rgba(247, 239, 223, 0.54);
  font-size: 24rpx;
  line-height: 1.5;
}

.archive-card > text {
  color: #b49355;
  font-size: 23rpx;
  font-weight: 900;
}

.rank-list {
  margin-top: 22rpx;
  display: grid;
  gap: 12rpx;
}

.rank-row {
  min-height: 82rpx;
  padding: 14rpx 16rpx;
  display: grid;
  grid-template-columns: 44rpx 1fr auto;
  gap: 16rpx;
  align-items: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
}

.rank-row.me {
  border: 1rpx solid rgba(241, 210, 125, 0.26);
  background: rgba(201, 157, 76, 0.08);
}

.rank-row > text:first-child,
.rank-row > text:last-child {
  color: #f6d886;
  font-size: 28rpx;
  font-weight: 900;
}

.rank-row view text:first-child {
  display: block;
  color: #fff7e7;
  font-size: 26rpx;
  font-weight: 900;
}

.rank-row view text:last-child {
  display: block;
  margin-top: 6rpx;
  color: rgba(247, 239, 223, 0.46);
  font-size: 21rpx;
}

.reflection-list,
.tribe-list,
.story-list {
  margin-top: 22rpx;
  display: grid;
  gap: 14rpx;
}

.reflection-row,
.tribe-row,
.story-row {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
}

.reflection-row > view:first-child {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.reflection-row text:first-child,
.story-row > text {
  color: #f6d886;
  font-size: 25rpx;
  font-weight: 900;
}

.reflection-row text:last-child,
.story-row view:first-of-type {
  color: rgba(88, 194, 173, 0.86);
  font-size: 21rpx;
  font-weight: 900;
}

.reflection-row > view:last-child,
.story-row view:last-child {
  margin-top: 12rpx;
  color: rgba(247, 239, 223, 0.7);
  font-size: 25rpx;
  line-height: 1.58;
}

.tribe-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
}

.tribe-row.active {
  border: 1rpx solid rgba(241, 210, 125, 0.28);
  background: rgba(201, 157, 76, 0.08);
}

.tribe-row > view:first-child text:first-child {
  display: block;
  color: #fff7e7;
  font-size: 26rpx;
  font-weight: 900;
}

.tribe-row > view:first-child text:last-child {
  display: block;
  margin-top: 8rpx;
  color: rgba(247, 239, 223, 0.48);
  font-size: 21rpx;
}

.tribe-row > view:last-child {
  flex: 0 0 100rpx;
  text-align: right;
}

.tribe-row > view:last-child text:first-child {
  display: block;
  color: #f6d886;
  font-size: 30rpx;
  font-weight: 900;
}

.tribe-row > view:last-child text:last-child {
  display: block;
  margin-top: 6rpx;
  color: rgba(247, 239, 223, 0.44);
  font-size: 20rpx;
}

.companion-guard {
  margin-top: 24rpx;
  color: rgba(247, 239, 223, 0.44);
  font-size: 22rpx;
  line-height: 1.55;
  text-align: center;
}

@media (max-width: 340px) {
  .dojo-shell {
    padding-left: 34rpx;
    padding-right: 34rpx;
  }

  .task-actions {
    grid-template-columns: 1fr;
  }

  .companion-stats {
    grid-template-columns: repeat(2, 1fr);
  }

  .handoff-row {
    grid-template-columns: 1fr;
  }
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(32rpx) scale(0.985);
    filter: blur(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes grainDrift {
  from { background-position: 0 0; }
  to { background-position: 92rpx 184rpx; }
}

@keyframes threadFlow {
  0%, 100% { opacity: 0.28; transform: scaleX(0.76); }
  50% { opacity: 0.9; transform: scaleX(1); }
}
