<view class="page-shell">
  <view class="page-content">
    <text class="eyebrow">LIVING MIRROR · 行为印记</text>
    <view class="page-title">活镜成长<br />训练台</view>
    <view class="page-subtitle">这里不是报告展示页，而是把每次真实复盘沉淀成九镜变化、心贼频次和下一次训练动作。</view>

    <view class="mirror-bridge card">
      <view class="bridge-line">复盘，是你写下事实。活镜，是系统照见反复出现的念头。</view>
      <view class="journey-progress-grid">
        <view>
          <text>今日训练</text>
          <view>{{unifiedJourneyView.dailyPracticeDay}}</view>
        </view>
        <view>
          <text>全年修行</text>
          <view>{{unifiedJourneyView.annualPracticeDay}}</view>
        </view>
        <view>
          <text>七日复测</text>
          <view>{{unifiedJourneyView.sevenDayProgress}}</view>
        </view>
        <view>
          <text>今日三印</text>
          <view>{{unifiedJourneyView.todaySealProgress}}</view>
        </view>
      </view>
      <view class="bridge-map">
        <view>
          <text>真实复盘</text>
          <view>上传截图，写下理由与第一念</view>
        </view>
        <view>
          <text>活镜照见</text>
          <view>把记录归入九镜六贼与训练动作</view>
        </view>
        <view>
          <text>心镜档案</text>
          <view>保存长期变化，等待复测校准</view>
        </view>
      </view>
    </view>

    <view class="mirror-hero card">
      <view class="lake-glow"></view>
      <view class="mirror-label">复盘生成主镜</view>
      <view class="mirror-name">{{stats.currentMirror || '活镜未点亮'}}</view>
      <view class="mirror-count">{{hasRecords ? stats.totalReviews + ' 条真实复盘' : '上传第一条记录后生成'}}</view>
      <view class="thief-line">
        <text>最近高频心贼</text>
        <view>{{stats.topThievesText || '待照见'}}</view>
      </view>
    </view>

    <view class="stability-card card">
      <view class="card-head">
        <text>知行稳定度</text>
        <view>{{zhixingStability.level}}</view>
      </view>
      <view class="stability-score">
        <text>{{zhixingStability.totalText}}</text>
        <view>/ 100</view>
      </view>
      <view class="stability-summary">{{zhixingStability.summary}}</view>
      <view class="stability-dimension-list">
        <view wx:for="{{zhixingStability.dimensions}}" wx:key="key" class="stability-dimension-row">
          <view class="dimension-title">
            <text>{{item.name}}</text>
            <view>{{item.scoreText}}</view>
          </view>
          <view class="dimension-bar"><view style="width: {{item.score}}%;"></view></view>
          <view class="dimension-hint">{{item.hint}}</view>
        </view>
      </view>
      <view class="stability-foot">{{zhixingStability.riskLine}}</view>
    </view>

    <view class="triple-card card">
      <view class="card-head">
        <text>三证互照</text>
        <view>{{tripleReflection.evidenceLevelText || tripleReflection.stateLabel}}</view>
      </view>
      <view wx:if="{{tripleReflection.unifiedConclusion}}" class="triple-conclusion">{{tripleReflection.unifiedConclusion}}</view>
      <view wx:if="{{tripleReflection.proofLine}}" class="triple-prescription">{{tripleReflection.proofLine}}</view>
      <view class="triple-conclusion">{{tripleReflection.conclusion}}</view>
      <view class="triple-row-list">
        <view wx:for="{{tripleReflection.rows}}" wx:key="key" class="triple-row">
          <text>{{item.name}}</text>
          <view>{{item.mirror}}</view>
          <text>{{item.statusText}}</text>
        </view>
      </view>
      <view class="triple-prescription">{{tripleReflection.nextCalibration || tripleReflection.prescription}}</view>
    </view>

    <view class="server-prescription-card card">
      <view class="card-head">
        <text>中枢今日训练</text>
        <view>{{prescriptionStatusText}}</view>
      </view>
      <view class="prescription-title">{{serverPrescription.title || '等待网页中枢下发'}}</view>
      <view class="prescription-action">{{serverPrescription.action || '完成测评、K线观心或真实复盘后，网页中枢会生成今日训练。'}}</view>
      <view class="prescription-meta">
        <text>{{serverPrescription.mirror || '待照见'}}</text>
        <text>Day {{serverPrescription.day || training7View.currentDay}}</text>
        <text>{{serverPrescription.klinePractice.actionText || 'K线观心待生成'}}</text>
      </view>
      <button class="primary-btn" bindtap="receiveServerPrescription">接收今日训练</button>
    </view>

    <view class="mirror-tree-card card">
      <view class="tree-glow"></view>
      <view class="card-head">
        <text>活镜树</text>
        <view>真实记录长出来的树</view>
      </view>
      <view class="tree-visual">
        <view class="tree-crown">
          <view wx:for="{{mirrorTree.nodes}}" wx:key="key" class="{{item.active ? 'active' : ''}}">
            <text>{{item.label}}</text>
            <view>{{item.value}}</view>
          </view>
        </view>
        <view class="tree-trunk">{{mirrorTree.trunk}}</view>
        <view class="tree-root">{{mirrorTree.root}}</view>
      </view>
      <view class="tree-lines">
        <view>{{mirrorTree.branchText}}</view>
        <view>{{mirrorTree.leafText}} · {{mirrorTree.ringsText}}</view>
        <view>{{mirrorTree.shadowText}}</view>
      </view>
    </view>

    <view class="evidence-tree-card card">
      <view class="card-head">
        <text>闭环印记</text>
        <view>{{evidenceSummary.total ? evidenceSummary.total + ' 条入树' : '待第一枚心证入树'}}</view>
      </view>
      <view wx:if="{{evidenceRows.length}}" class="evidence-tree-list">
        <view wx:for="{{evidenceRows}}" wx:key="id">
          <text>{{item.typeLabel}}</text>
          <view>{{item.title}}</view>
          <text>{{item.createdAtText}}</text>
        </view>
      </view>
      <view wx:else class="empty-text">完成今日落印后，第一枚心证会长成活镜树的一片叶。</view>
    </view>

    <view class="change-card card">
      <view class="card-head">
        <text>7 天印记变化</text>
        <view>只看反应模式，不绑定结果</view>
      </view>
      <view class="change-row" wx:for="{{stats.mirrorTrendRows}}" wx:key="mirror">
        <text>{{item.mirror}}</text>
        <view class="{{item.tone}}">{{item.direction}} {{item.percent}}</view>
      </view>
    </view>

    <view class="kline-retest-card card">
      <view class="card-head">
        <text>{{klineDayRetest.title}}</text>
        <view>{{klineDayRetest.stageText}}</view>
      </view>
      <view class="retest-line">{{klineDayRetest.mirrorLine}}</view>
      <view class="retest-grid">
        <view wx:for="{{klineDayRetest.metrics}}" wx:key="key">
          <text>{{item.label}}</text>
          <view>{{item.value}}</view>
        </view>
      </view>
      <view class="retest-insight">{{klineDayRetest.insight}}</view>
    </view>

    <view class="training-progress-card card">
      <view class="card-head">
        <text>训练进度</text>
        <view>Day {{training7View.currentDay}} · {{training7View.progressText}}</view>
      </view>
      <view class="training-bar"><view style="width: {{training7View.progressPercent}}%;"></view></view>
      <view class="training-today">
        <text>{{training7View.today.title}}</text>
        <view>{{training7View.today.boundaryPractice}}</view>
      </view>
    </view>

    <view class="loop-card card">
      <view class="card-head">
        <text>{{miniLoopProgress.behaviorLoop.title || '循环之镜'}}</text>
        <view>重复反应路径</view>
      </view>
      <view class="loop-line">{{mirrorTree.loopLine}}</view>
      <view class="loop-next">{{miniLoopProgress.behaviorLoop.nextAction || '完成两次复盘后生成下一次提醒。'}}</view>
    </view>

    <view class="reminder-card card">
      <view class="card-head">
        <text>下一次训练提醒</text>
        <view>今日只练一件事</view>
      </view>
      <view class="reminder-line">{{stats.todayReminder || '先完成一条真实复盘，让活镜开始记录。'}}</view>
      <view class="training-line">{{stats.mainTraining || '把第一念记录下来。'}}</view>
      <button class="primary-btn" bindtap="goReview">{{hasRecords ? '继续记录一笔复盘' : '上传第一条记录'}}</button>
    </view>

    <view class="recommend-card card">
      <view class="card-head">
        <text>活镜推荐切片</text>
        <view>按当前主镜生成</view>
      </view>
      <view class="recommend-title">{{klineRecommendation.title}}</view>
      <view class="recommend-reason">{{klineRecommendation.reason}}</view>
      <view class="recommend-meta">{{klineRecommendation.marketLabel}} · {{klineRecommendation.timeframeLabel}} · Day {{klineRecommendation.trainingDay}}</view>
      <button class="primary-btn" bindtap="goRecommendedKline">{{klineRecommendation.actionText}}</button>
    </view>

    <view class="recent-card card">
      <view class="card-head">
        <text>最近三次复盘</text>
        <view bindtap="goArchive">进入档案</view>
      </view>
      <view wx:if="{{stats.recentThree.length}}">
        <button
          wx:for="{{stats.recentThree}}"
          wx:key="id"
          class="recent-row"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >{{item.line}}</button>
      </view>
      <view wx:else class="empty-text">还没有复盘记录。先上传一张截图，照见第一次真实反应。</view>
    </view>

    <view class="assistant-card card">
      <view class="card-head">
        <text>助教承接摘要</text>
        <view>本地记录</view>
      </view>
      <view class="assistant-grid">
        <view>
          <text>当前主镜</text>
          <view>{{stats.assistantHandoff.currentMirror}}</view>
        </view>
        <view>
          <text>当前副镜</text>
          <view>{{stats.assistantHandoff.secondaryMirror}}</view>
        </view>
        <view>
          <text>高频心贼</text>
          <view>{{stats.assistantHandoff.highFrequencyThieves}}</view>
        </view>
        <view>
          <text>最近念头</text>
          <view>{{stats.assistantHandoff.recentThought}}</view>
        </view>
      </view>
      <view class="assistant-script">{{stats.assistantHandoff.scriptSuggestion}}</view>
      <view class="event-timeline" wx:if="{{stats.assistantHandoff.eventTimeline.length}}">
        <view wx:for="{{stats.assistantHandoff.eventTimeline}}" wx:key="id">
          <text>{{item.label}}</text>
          <view>{{item.detail}}</view>
        </view>
      </view>
      <button class="ghost-btn" bindtap="goAssistant">去我的页承接</button>
    </view>

    <compliance-notice />
  </view>
  <bottom-tab-bar active="mirror" />
</view>
