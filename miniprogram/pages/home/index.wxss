@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(30rpx) scale(0.986);
    filter: blur(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes edictBreath {
  0%, 100% {
    opacity: 0.12;
    transform: translate3d(-18rpx, 0, 0);
  }
  50% {
    opacity: 0.22;
    transform: translate3d(18rpx, 0, 0);
  }
}

@keyframes edictFadeIn {
  from {
    opacity: 0;
    transform: translateY(18rpx);
    filter: blur(6rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
}

@keyframes edictGlowBreath {
  0%, 100% {
    opacity: 0.52;
    transform: scale(1);
  }
  50% {
    opacity: 0.78;
    transform: scale(1.03);
  }
}

@keyframes ripple {
  from {
    opacity: 0.34;
    transform: scale(0.4);
  }
  to {
    opacity: 0;
    transform: scale(9);
  }
}

@keyframes entryRitualFade {
  0% {
    opacity: 0;
  }
  18%,
  72% {
    opacity: 1;
  }
  100% {
    opacity: 0;
  }
}

@keyframes entryRitualLand {
  0% {
    opacity: 0;
    transform: translateY(18rpx) scale(0.94);
  }
  38% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  100% {
    opacity: 1;
    transform: translateY(-4rpx) scale(0.985);
  }
}

@keyframes posterReveal {
  from {
    opacity: 0;
    transform: scale(1.015);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes sealLand {
  0% {
    transform: scale(1.55) rotate(-10deg);
    filter: blur(1rpx);
  }
  48% {
    transform: scale(0.92) rotate(3deg);
    filter: blur(0);
  }
  100% {
    transform: scale(1) rotate(0deg);
  }
}

@keyframes sealAura {
  0% {
    opacity: 0.48;
    transform: scale(0.3);
  }
  100% {
    opacity: 0;
    transform: scale(1.7);
  }
}

@keyframes vowPress {
  0% {
    transform: translateY(0) scale(1);
  }
  38% {
    transform: translateY(5rpx) scale(0.986);
  }
  100% {
    transform: translateY(0) scale(1);
  }
}

@keyframes imprintBloom {
  0% {
    opacity: 0;
    transform: scale(0.68);
  }
  34% {
    opacity: 0.82;
    transform: scale(1);
  }
  100% {
    opacity: 0.16;
    transform: scale(1.08);
  }
}

@keyframes sealSoftPulse {
  0%, 100% {
    box-shadow: 0 0 0 rgba(154, 73, 48, 0);
    transform: rotate(8deg) scale(1);
  }
  50% {
    box-shadow: 0 0 28rpx rgba(154, 73, 48, 0.18);
    transform: rotate(8deg) scale(1.04);
  }
}

@keyframes todaySealDrop {
  0% {
    opacity: 0;
    transform: translate3d(0, -86rpx, 0) scale(1.48) rotate(-18deg);
    filter: blur(2rpx);
  }
  38% {
    opacity: 0.92;
    transform: translate3d(0, 0, 0) scale(0.94) rotate(-10deg);
    filter: blur(0);
  }
  72% {
    opacity: 0.76;
    transform: translate3d(0, 0, 0) scale(1) rotate(-12deg);
  }
  100% {
    opacity: 0;
    transform: translate3d(0, 10rpx, 0) scale(1.04) rotate(-12deg);
  }
}

@keyframes lampBreath {
  0%, 100% {
    opacity: 0.58;
    transform: scale(0.86);
  }
  50% {
    opacity: 1;
    transform: scale(1.12);
  }
}

@keyframes mountainDrift {
  from { transform: translate3d(-16rpx, 0, 0); }
  to { transform: translate3d(18rpx, -10rpx, 0); }
}

@keyframes grainDrift {
  from { background-position: 0 0; }
  to { background-position: 96rpx 192rpx; }
}

@keyframes buttonGoldFlow {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

