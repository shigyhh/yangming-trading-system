.ritual-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: calc(36rpx + env(safe-area-inset-top)) 52rpx calc(240rpx + env(safe-area-inset-bottom));
  color: #f7efdf;
  background:
    radial-gradient(circle at 72% 12%, rgba(218, 180, 92, 0.07), transparent 28%),
    radial-gradient(circle at 12% 72%, rgba(49, 85, 78, 0.09), transparent 34%),
    linear-gradient(180deg, #0a1116 0%, #07100f 48%, #030606 100%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", "Microsoft YaHei", sans-serif;
}

.mist-layer,
.grain-layer,
.ink-mountains {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.mist-layer {
  opacity: 0.68;
  background:
    radial-gradient(ellipse at 48% 20%, rgba(255, 246, 226, 0.045), transparent 42%),
    linear-gradient(118deg, transparent 0 24%, rgba(255, 255, 255, 0.02) 42%, transparent 68%);
}

.grain-layer {
  opacity: 0.07;
  background:
    linear-gradient(90deg, rgba(241, 210, 125, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(241, 210, 125, 0.03) 1rpx, transparent 1rpx);
  background-size: 96rpx 96rpx;
  animation: grainDrift 28s linear infinite;
}

.mountain {
  position: absolute;
  left: 50%;
  bottom: -140rpx;
  width: 920rpx;
  height: 360rpx;
  transform: translateX(-50%) rotate(-4deg);
  border-radius: 48% 52% 0 0;
  background: linear-gradient(180deg, rgba(19, 32, 35, 0.58), rgba(5, 8, 7, 0));
  filter: blur(1rpx);
}

.mountain-b {
  left: 16%;
  bottom: -160rpx;
  width: 720rpx;
  opacity: 0.58;
  transform: rotate(7deg);
}

.mountain-c {
  left: 86%;
  bottom: -180rpx;
  width: 660rpx;
  opacity: 0.5;
  transform: rotate(-10deg);
}

.ink-mountains {
  animation: mountainDrift 34s ease-in-out infinite alternate;
}

.mind-ripple {
  position: fixed;
  z-index: 8;
  width: 18rpx;
  height: 18rpx;
  margin-left: -9rpx;
  margin-top: -9rpx;
  border-radius: 50%;
  border: 0;
  background: radial-gradient(circle, rgba(241, 210, 125, 0.28), rgba(241, 210, 125, 0.08) 36%, transparent 72%);
  box-shadow: 0 0 22rpx rgba(241, 210, 125, 0.08);
  animation: ripple 0.46s ease-out forwards;
  pointer-events: none;
}

.entry-ritual {
  position: fixed;
  z-index: 30;
  inset: 0;
  display: grid;
  place-items: center;
  padding: 56rpx;
  background:
    radial-gradient(circle at 50% 42%, rgba(216, 183, 111, 0.1), transparent 38%),
    rgba(5, 7, 6, 0.78);
  backdrop-filter: blur(10rpx);
  animation: entryRitualFade 0.98s ease-in-out both;
}

.entry-ritual-card {
  display: grid;
  justify-items: center;
  gap: 14rpx;
  transform-origin: center;
  animation: entryRitualLand 0.82s cubic-bezier(0.2, 0.9, 0.2, 1) both;
}

.entry-ritual-seal {
  width: 108rpx;
  height: 108rpx;
  display: grid;
  place-items: center;
  border-radius: 30rpx;
  color: rgba(255, 235, 204, 0.94);
  border: 3rpx solid rgba(120, 60, 45, 0.7);
  background:
    radial-gradient(circle at 50% 38%, rgba(255, 244, 214, 0.16), transparent 46%),
    rgba(120, 60, 45, 0.48);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.12),
    0 18rpx 60rpx rgba(0, 0, 0, 0.34),
    0 0 56rpx rgba(120, 60, 45, 0.18);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 64rpx;
  font-weight: 800;
  transform: rotate(-5deg);
}

.entry-ritual-card text {
  color: rgba(244, 235, 221, 0.92);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.2;
}

.entry-ritual-card view:last-child {
  color: rgba(244, 235, 221, 0.52);
  font-size: 22rpx;
  line-height: 1.4;
}

.ritual-content {
  position: relative;
  z-index: 2;
  min-height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  animation: riseIn 0.78s cubic-bezier(0.19, 1, 0.22, 1) both;
}

.scene {
  position: relative;
}

.scene-ordinal {
  margin-bottom: 32rpx;
  color: rgba(230, 189, 98, 0.3);
  font-size: 19rpx;
  font-weight: 700;
  letter-spacing: 0.22em;
}

.scene-edict {
  min-height: calc(100vh - 104rpx - env(safe-area-inset-top));
  padding-top: 8rpx;
  display: flex;
  flex-direction: column;
}

.brand-block {
  display: flex;
  align-items: center;
  gap: 20rpx;
  opacity: 0.82;
}

.brand-badge {
  width: 66rpx;
  height: 66rpx;
  flex: 0 0 66rpx;
  display: grid;
  place-items: center;
  border-radius: 22rpx;
  color: #e6bd62;
  border: 1rpx solid rgba(230, 189, 98, 0.24);
  background: rgba(12, 18, 17, 0.66);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.1), 0 16rpx 36rpx rgba(0, 0, 0, 0.2);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 38rpx;
  font-weight: 500;
}

.brand-block text {
  display: block;
}

.brand-block text:first-child {
  color: rgba(255, 246, 230, 0.88);
  font-size: 24rpx;
  font-weight: 700;
}

.brand-block text:last-child {
  margin-top: 6rpx;
  color: rgba(247, 239, 223, 0.36);
  font-size: 19rpx;
}

.edict-card {
  position: relative;
  min-height: 540rpx;
  margin-top: 96rpx;
  padding: 56rpx 42rpx 44rpx;
  overflow: hidden;
  border-radius: 10rpx 34rpx 10rpx 34rpx;
  border: 1rpx solid rgba(230, 189, 98, 0.055);
  background:
    linear-gradient(90deg, rgba(230, 189, 98, 0.055), transparent 9%, transparent 91%, rgba(230, 189, 98, 0.045)),
    radial-gradient(circle at 76% 20%, rgba(230, 189, 98, 0.075), transparent 34%),
    linear-gradient(145deg, rgba(255, 247, 231, 0.052), rgba(255, 255, 255, 0.014) 48%, rgba(3, 7, 7, 0.2));
  box-shadow:
    inset 0 1rpx 0 rgba(255, 247, 231, 0.06),
    inset 0 -1rpx 0 rgba(230, 189, 98, 0.05),
    0 36rpx 80rpx rgba(0, 0, 0, 0.22);
}

.edict-card::before {
  content: "";
  position: absolute;
  inset: 24rpx 22rpx;
  border: 1rpx solid rgba(230, 189, 98, 0.03);
  pointer-events: none;
}

.edict-card::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 100%;
  opacity: 0.18;
  background:
    linear-gradient(110deg, transparent 0 38%, rgba(255, 247, 231, 0.1) 46%, transparent 58%),
    repeating-linear-gradient(90deg, rgba(255, 247, 231, 0.035) 0 1rpx, transparent 1rpx 46rpx);
  animation: edictBreath 8s ease-in-out infinite;
  pointer-events: none;
}

.edict-card.ready {
  border-color: rgba(230, 189, 98, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 247, 231, 0.08),
    inset 0 -1rpx 0 rgba(230, 189, 98, 0.07),
    0 40rpx 92rpx rgba(0, 0, 0, 0.24),
    0 0 42rpx rgba(230, 189, 98, 0.045);
}

.scroll-line {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(230, 189, 98, 0.16), transparent);
}

.scroll-line.top {
  top: 26rpx;
}

.scroll-line.bottom {
  bottom: 26rpx;
}

.edict-card-head {
  position: relative;
  z-index: 1;
  display: block;
}

.hero-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  color: rgba(230, 189, 98, 0.48);
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
}

.hero-meta text + text::before {
  content: "";
  display: inline-block;
  width: 4rpx;
  height: 4rpx;
  margin-right: 16rpx;
  vertical-align: middle;
  border-radius: 50%;
  background: rgba(230, 189, 98, 0.42);
}

.edict-overline {
  position: relative;
  z-index: 1;
  margin-top: 58rpx;
  color: rgba(230, 189, 98, 0.46);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.28em;
}

.edict-title {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  max-width: 560rpx;
  color: #fff7e7;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", "STSong", serif;
  font-size: 82rpx;
  font-weight: 500;
  line-height: 1.16;
}

.edict-guide {
  position: relative;
  z-index: 1;
  margin-top: 44rpx;
  max-width: 560rpx;
  color: rgba(247, 239, 223, 0.52);
  font-size: 25rpx;
  line-height: 1.72;
}

.scene-edict.edict-hero {
  min-height: calc(100vh - 112rpx);
  margin: calc(-36rpx - env(safe-area-inset-top)) -52rpx 0;
  padding: calc(env(safe-area-inset-top) + 70rpx) 34rpx calc(160rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at 72% 12%, rgba(216, 183, 111, 0.11), transparent 30%),
    radial-gradient(circle at 18% 82%, rgba(95, 132, 117, 0.12), transparent 36%),
    radial-gradient(ellipse at 50% 100%, rgba(17, 16, 13, 0.96), transparent 64%),
    linear-gradient(180deg, #080807 0%, #0c0f0d 48%, #050606 100%);
}

.edict-hero::before,
.edict-hero::after,
.edict-bg {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.edict-hero::before {
  opacity: 0.72;
  background:
    linear-gradient(90deg, rgba(216, 183, 111, 0.04), transparent 18%, transparent 82%, rgba(216, 183, 111, 0.035)),
    linear-gradient(180deg, rgba(244, 235, 221, 0.035), transparent 34%),
    radial-gradient(ellipse at 50% 100%, rgba(95, 132, 117, 0.18), transparent 62%);
}

.edict-hero::after {
  opacity: 0.085;
  background:
    radial-gradient(circle at 18% 18%, rgba(244, 235, 221, 0.3) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 72% 48%, rgba(216, 183, 111, 0.24) 0 1rpx, transparent 2rpx),
    repeating-linear-gradient(90deg, rgba(244, 235, 221, 0.035) 0 1rpx, transparent 1rpx 56rpx);
  background-size: 74rpx 86rpx, 112rpx 98rpx, 100% 100%;
}

.edict-bg-glow {
  opacity: 0.72;
  background:
    radial-gradient(circle at 50% 18%, rgba(216, 183, 111, 0.16), transparent 33%),
    linear-gradient(112deg, transparent 10%, rgba(216, 183, 111, 0.07) 45%, transparent 72%),
    radial-gradient(circle at 24% 72%, rgba(95, 132, 117, 0.12), transparent 34%);
  animation: edictGlowBreath 11s ease-in-out infinite;
}

.edict-bg-mountain {
  top: auto;
  bottom: -140rpx;
  height: 430rpx;
  opacity: 0.24;
  background:
    radial-gradient(ellipse at 50% 100%, rgba(95, 132, 117, 0.28), transparent 68%),
    linear-gradient(172deg, transparent 0 42%, rgba(95, 132, 117, 0.18) 58%, transparent 76%),
    linear-gradient(14deg, transparent 0 48%, rgba(244, 235, 221, 0.04) 52%, transparent 68%);
  filter: blur(2rpx);
}

.edict-bg-grain {
  opacity: 0.1;
  background:
    radial-gradient(circle at 18% 20%, rgba(244, 235, 221, 0.13) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 72% 52%, rgba(216, 183, 111, 0.1) 0 1rpx, transparent 2rpx);
  background-size: 46rpx 52rpx, 58rpx 64rpx;
  animation: grainDrift 32s linear infinite;
}

.edict-header,
.edict-scroll {
  position: relative;
  z-index: 2;
}

.edict-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 0 0 auto;
  animation: edictFadeIn 1s ease-out both;
}

.brand-seal {
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  display: grid;
  place-items: center;
  border-radius: 20rpx;
  color: rgba(244, 235, 221, 0.86);
  border: 2rpx solid rgba(120, 60, 45, 0.55);
  background:
    radial-gradient(circle at 50% 45%, rgba(120, 60, 45, 0.42), rgba(17, 16, 13, 0.38) 68%),
    rgba(244, 235, 221, 0.025);
  box-shadow:
    inset 0 1rpx 0 rgba(244, 235, 221, 0.12),
    0 14rpx 34rpx rgba(0, 0, 0, 0.3);
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", serif;
  font-size: 42rpx;
  font-weight: 500;
}

.brand-seal.brand-zhao-mini {
  font-size: 0;
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  color: rgba(244, 235, 221, 0.9);
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.25;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: rgba(216, 183, 111, 0.42);
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 0.14em;
}

.mini-mirror-card {
  position: relative;
  z-index: 2;
  margin-top: 26rpx;
  padding: 26rpx 24rpx 24rpx;
  overflow: hidden;
  border-radius: 28rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.18);
  background:
    radial-gradient(circle at 82% 10%, rgba(216, 183, 111, 0.13), transparent 36%),
    radial-gradient(circle at 10% 92%, rgba(95, 132, 117, 0.12), transparent 34%),
    linear-gradient(145deg, rgba(244, 235, 221, 0.075), rgba(244, 235, 221, 0.018) 48%, rgba(5, 8, 7, 0.38)),
    rgba(12, 18, 16, 0.78);
  box-shadow:
    inset 0 1rpx 0 rgba(244, 235, 221, 0.08),
    0 34rpx 92rpx rgba(0, 0, 0, 0.34);
  animation: edictFadeIn 1.05s 0.08s ease-out both;
}

.mini-mirror-card::before {
  content: "";
  position: absolute;
  inset: 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(217, 189, 122, 0.055);
  pointer-events: none;
}

.mini-mirror-card::after {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.62;
  pointer-events: none;
  background:
    linear-gradient(112deg, transparent 8%, rgba(216, 183, 111, 0.07) 46%, transparent 68%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 34%);
}

.daily-state-row,
.daily-progress-grid,
.daily-proof,
.mini-mirror-one,
.living-written,
.mini-primary,
.mini-primary-hint {
  position: relative;
  z-index: 1;
}

.daily-state-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  color: rgba(244, 235, 221, 0.46);
}

.daily-state-row > text {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(216, 183, 111, 0.82);
  border: 1rpx solid rgba(217, 189, 122, 0.16);
  background: rgba(216, 183, 111, 0.055);
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1.2;
}

.daily-state-row > view {
  min-width: 0;
  color: rgba(244, 235, 221, 0.76);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.42;
  text-align: right;
}

.daily-progress-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  border-top: 1rpx solid rgba(217, 189, 122, 0.08);
  border-bottom: 1rpx solid rgba(217, 189, 122, 0.08);
}

.daily-progress-grid > view {
  min-width: 0;
  padding: 14rpx 8rpx;
  border-right: 1rpx solid rgba(217, 189, 122, 0.06);
  text-align: center;
}

.daily-progress-grid > view:last-child {
  border-right: 0;
}

.daily-progress-grid text {
  display: block;
  color: rgba(216, 183, 111, 0.48);
  font-size: 17rpx;
  font-weight: 900;
  line-height: 1.24;
}

.daily-progress-grid view view {
  margin-top: 7rpx;
  color: rgba(244, 235, 221, 0.86);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.24;
}

.daily-proof {
  margin-top: 4rpx;
}

.mini-mirror-eyebrow {
  color: rgba(216, 183, 111, 0.64);
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.26em;
}

.daily-proof-lines {
  margin-top: 12rpx;
  color: #fff6e6;
  font-family: "ZX-LXGW", "LXGW WenKai", "霞鹜文楷", "Songti SC", serif;
  font-size: 48rpx;
  font-weight: 600;
  line-height: 1.22;
  text-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.32);
}

.daily-proof-lines text {
  display: block;
}

.daily-proof-lines text + text {
  margin-top: 6rpx;
}

.mini-mirror-one {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-left: 4rpx solid rgba(95, 132, 117, 0.62);
  border-radius: 0 20rpx 20rpx 0;
  background:
    linear-gradient(90deg, rgba(95, 132, 117, 0.12), rgba(244, 235, 221, 0.018));
}

.mini-mirror-one > text {
  display: block;
  color: rgba(216, 183, 111, 0.56);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.18em;
}

.mini-mirror-one > view {
  margin-top: 8rpx;
  color: rgba(244, 235, 221, 0.82);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.48;
}

.living-written {
  margin-top: 24rpx;
  padding: 20rpx;
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  border-radius: 22rpx;
  border: 1rpx solid rgba(120, 60, 45, 0.24);
  background: rgba(120, 60, 45, 0.11);
}

.living-written-mark {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  border-radius: 50%;
  color: rgba(255, 236, 205, 0.9);
  border: 2rpx solid rgba(154, 73, 48, 0.62);
  background: rgba(120, 60, 45, 0.32);
  font-size: 0;
}

.living-written-mark .zhao-eye {
  width: 13rpx;
  height: 12rpx;
  border-width: 2rpx;
}

.living-written-mark .zhao-mirror {
  width: 34rpx;
  height: 2rpx;
}

.living-written-mark .zhao-fire {
  gap: 14rpx;
}

.living-written-mark .zhao-fire-dot {
  width: 3rpx;
  height: 14rpx;
}

.living-written-copy text {
  display: block;
  color: rgba(244, 235, 221, 0.88);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.4;
}

.living-written-copy view {
  margin-top: 6rpx;
  color: rgba(244, 235, 221, 0.52);
  font-size: 21rpx;
  line-height: 1.45;
}

.mini-primary {
  width: 100%;
  min-height: 82rpx;
  margin-top: 22rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #10110c;
  border: 1rpx solid rgba(241, 210, 125, 0.58);
  background:
    linear-gradient(180deg, rgba(255, 248, 216, 0.36), rgba(255, 255, 255, 0.05) 35%, transparent 54%),
    linear-gradient(180deg, rgba(241, 210, 125, 0.96), rgba(189, 140, 54, 0.94));
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.22),
    0 18rpx 38rpx rgba(188, 137, 52, 0.18),
    0 18rpx 46rpx rgba(0, 0, 0, 0.28);
  font-size: 26rpx;
  font-weight: 950;
  line-height: 1.24;
  text-align: center;
}

.mini-primary-hint {
  margin-top: 9rpx;
  padding: 0 18rpx;
  color: rgba(244, 235, 221, 0.46);
  font-size: 20rpx;
  line-height: 1.4;
  text-align: center;
}

.kline-mind-entry {
  position: relative;
  z-index: 2;
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(95, 132, 117, 0.18);
  background:
    linear-gradient(90deg, rgba(95, 132, 117, 0.12), rgba(244, 235, 221, 0.018)),
    rgba(8, 8, 7, 0.3);
  box-shadow:
    inset 0 1rpx 0 rgba(244, 235, 221, 0.045),
    0 18rpx 42rpx rgba(0, 0, 0, 0.18);
}

.kline-mind-entry > view {
  min-width: 0;
}

.kline-mind-entry > view > text {
  display: block;
  color: rgba(244, 235, 221, 0.84);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.kline-mind-entry > view > view {
  margin-top: 6rpx;
  color: rgba(244, 235, 221, 0.44);
  font-size: 20rpx;
  line-height: 1.42;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.kline-mind-entry > text {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: rgba(216, 183, 111, 0.86);
