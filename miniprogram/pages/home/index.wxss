    flex-direction: column;
    justify-content: center;
    gap: 8rpx;
  }

  .retention-next view {
    text-align: left;
  }

  .edict-poster-mode {
    padding: calc(env(safe-area-inset-top) + 54rpx) 44rpx calc(env(safe-area-inset-bottom) + 48rpx);
  }

  .poster-header {
    gap: 18rpx;
  }

  .poster-seal {
    width: 72rpx;
    height: 72rpx;
    border-radius: 22rpx;
    font-size: 40rpx;
  }

  .poster-brand {
    font-size: 25rpx;
  }

  .poster-subtitle {
    font-size: 18rpx;
    letter-spacing: 0.14em;
  }

  .poster-edict {
    padding: 70rpx 0 58rpx;
  }

  .poster-line {
    margin-bottom: 64rpx;
  }

  .poster-line.bottom {
    margin-top: 64rpx;
  }

  .poster-kicker,
  .poster-label {
    font-size: 20rpx;
  }

  .poster-label {
    margin-top: 58rpx;
  }

  .poster-proof {
    margin-top: 30rpx;
    max-width: 560rpx;
    font-size: 62rpx;
    line-height: 1.3;
  }

  .poster-footer {
    font-size: 19rpx;
  }

  .edict-card {
    min-height: 500rpx;
    margin-top: 62rpx;
    padding-left: 34rpx;
    padding-right: 34rpx;
  }

  .edict-card-head {
    display: block;
  }

  .hero-meta {
    flex-wrap: wrap;
  }

  .edict-title {
    font-size: 68rpx;
  }

  .edict-guide {
    font-size: 24rpx;
  }

  .primary-task-text {
    font-size: 36rpx;
    line-height: 1.42;
  }

  .scene-oath,
  .scene-practice,
  .scene-companion {
    margin-top: 88rpx;
    padding-top: 64rpx;
  }

  .vow-row {
    min-height: 108rpx;
    padding-left: 0;
    padding-right: 0;
  }

  .falling-seal {
    left: -10rpx;
    right: auto;
    width: 88rpx;
    height: 88rpx;
    margin-top: -44rpx;
    font-size: 22rpx;
  }

  .heart-card-teaser {
    min-height: 224rpx;
    padding-right: 128rpx;
  }

  .teaser-title {
    font-size: 32rpx;
  }

  .mini-heart-card {
    right: -42rpx;
    width: 150rpx;
    height: 210rpx;
  }

  .mini-card-proof {
    max-width: 108rpx;
    font-size: 28rpx;
  }

  .growth-grid {
    grid-template-columns: 1fr;
  }

  .growth-grid > view:last-child {
    grid-column: auto;
  }

  .lamp-field {
    height: 84rpx;
    gap: 10rpx;
  }

  .companion-copy text {
    font-size: 34rpx;
  }

  .echo-row {
    padding-left: 18rpx;
    padding-right: 18rpx;
  }
}
