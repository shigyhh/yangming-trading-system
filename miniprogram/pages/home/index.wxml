<view class="ritual-shell {{posterMode ? 'poster-open' : ''}}">
  <view class="mist-layer"></view>
  <view class="grain-layer"></view>
  <view class="ink-mountains">
    <view class="mountain mountain-a"></view>
    <view class="mountain mountain-b"></view>
    <view class="mountain mountain-c"></view>
  </view>

  <view class="ritual-content">
    <view class="scene scene-edict edict-hero">
      <view class="edict-bg edict-bg-glow"></view>
      <view class="edict-bg edict-bg-mountain"></view>
      <view class="edict-bg edict-bg-grain"></view>

      <view class="edict-header">
        <view class="brand-seal">知</view>
        <view class="brand-copy">
          <view class="brand-title">阳明心学交易系统</view>
          <view class="brand-subtitle">每日一页 · 照见本心</view>
        </view>
      </view>

      <view class="mini-mirror-card">
        <view class="daily-state-row">
          <text>{{miniHomeView.stateLabel}}</text>
          <view>{{unifiedJourneyView.currentTheme}}</view>
        </view>
        <view class="daily-progress-grid">
          <view>
            <text>今日训练</text>
            <view>{{unifiedJourneyView.dailyPracticeDay}}</view>
          </view>
          <view>
            <text>全年修行</text>
            <view>{{unifiedJourneyView.annualPracticeDay}}</view>
          </view>
          <view>
            <text>七日复测</text>
            <view>{{unifiedJourneyView.sevenDayProgress}}</view>
          </view>
          <view>
            <text>今日三印</text>
            <view>{{unifiedJourneyView.todaySealProgress}}</view>
          </view>
        </view>
        <view class="daily-proof">
          <view class="mini-mirror-eyebrow">今日心证</view>
          <view class="daily-proof-lines">
            <text wx:for="{{heroView.heartProofLines}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="mini-mirror-one">
          <text>今日只练一件事</text>
          <view>{{miniHomeView.todayOneThought}}</view>
        </view>
        <view wx:if="{{threeSeals.completed}}" class="living-written">
          <text>照</text>
          <view>
            <text>{{miniHomeView.livingMirrorFeedback}}</text>
            <view>{{miniHomeView.stateHint}}</view>
          </view>
        </view>
        <button data-noripple="1" class="mini-primary" bindtap="goMiniPrimary">{{miniHomeView.primaryText}}</button>
        <view wx:if="{{miniHomeView.primaryHint}}" class="mini-primary-hint">{{miniHomeView.primaryHint}}</view>
      </view>

      <view class="edict-scroll" bindlongpress="openPosterMode">
        <view class="practice-detail-head">
          <view class="edict-label">落印之后</view>
          <view>写下今日一念、一惧、一界，再进入真实复盘与 K 线观心。</view>
        </view>
        <view wx:if="{{journeyResumeView.visible && !completionView.done}}" class="journey-resume">
          <text>{{journeyResumeView.title}}</text>
          <view wx:if="{{journeyResumeView.completedText}}">
            已完成：{{journeyResumeView.completedText}}
          </view>
          <view wx:if="{{journeyResumeView.pendingText}}">
            未完成：{{journeyResumeView.pendingText}}
          </view>
        </view>
        <view wx:if="{{completionView.done}}" class="journey-complete">
          <view class="completion-seal">印</view>
          <view class="completion-kicker">落印完成</view>
          <text class="completion-title">{{completionView.title}}</text>
          <view class="completion-lines">
            <view>
              <text>你今天照见的是：</text>
              <view>{{completionView.thought}}</view>
            </view>
            <view>
              <text>你今天守住的是：</text>
              <view>{{completionView.boundary}}</view>
            </view>
          </view>
          <view class="completion-seals">
            <text>已落下今日三印</text>
            <view>{{completionView.sealText}}</view>
          </view>
          <view class="completion-proof-grid">
            <view>
              <text>{{completionView.heartProofText}}</text>
              <view>心证已写入今日闭环</view>
            </view>
            <view>
              <text>知行指数 {{completionView.zhixingChangeText}}</text>
              <view>只记录觉察、守界与复盘</view>
            </view>
            <view>
              <text>{{completionView.retestText}}</text>
              <view>七日只看反应变化</view>
            </view>
          </view>
          <view class="journey-complete-actions">
            <button
              wx:for="{{completionView.actions}}"
              wx:key="key"
              data-noripple="1"
              data-action="{{item.key}}"
              class="{{item.primary ? 'primary' : ''}}"
              bindtap="handleCompletionAction"
            >{{item.text}}</button>
          </view>
        </view>

        <view class="closure-chain-card">
          <view class="closure-chain-head">
            <view>
              <text>{{closureEvidenceChain.title}}</text>
              <view>{{closureEvidenceChain.subtitle}}</view>
            </view>
            <text>{{closureEvidenceChain.progressText}}</text>
          </view>
          <view class="closure-chain-list">
            <view
              wx:for="{{closureEvidenceChain.steps}}"
              wx:key="key"
              class="{{item.done ? 'done' : item.current ? 'current' : ''}}"
            >
              <text>{{item.numberText}}</text>
              <view>
                <text>{{item.title}}</text>
                <view>{{item.detail}}</view>
              </view>
              <text>{{item.statusText}}</text>
            </view>
          </view>
          <view class="closure-next-action">下一步：{{closureEvidenceChain.nextActionText}}</view>
        </view>

        <view class="three-seals-block">
          <view class="edict-label">今日之印</view>
          <view class="three-seal-field">
            <text>一念</text>
            <input data-key="thought" value="{{threeSeals.thought}}" bindinput="inputThreeSeal" placeholder="我今天最明显的念头是什么？" />
          </view>
          <view class="three-seal-field">
            <text>一惧</text>
            <input data-key="fear" value="{{threeSeals.fear}}" bindinput="inputThreeSeal" placeholder="我今天最怕发生什么？" />
          </view>
          <view class="three-seal-field">
            <text>一界</text>
            <input data-key="boundary" value="{{threeSeals.boundary}}" bindinput="inputThreeSeal" placeholder="我今天必须守住哪条边界？" />
          </view>
          <button data-noripple="1" class="three-seal-save" bindtap="saveThreeSeals">{{threeSeals.completed ? '更新今日之印' : '落下今日之印'}}</button>
          <view wx:if="{{threeSeals.completed}}" class="seal-open-panel">
            <view class="seal-mark-large">照</view>
            <view>
              <text>朱砂印落下：今日已照见</text>
              <view>今日训练已开启，下一步只做真实动作。</view>
            </view>
            <button data-noripple="1" bindtap="goTrainingDay">今日训练已开启</button>
            <button data-noripple="1" bindtap="goTradeReview">去复盘一笔交易</button>
            <button data-noripple="1" bindtap="goLivingMirror">查看活镜变化</button>
          </view>
        </view>

        <view wx:if="{{threeSeals.completed}}" class="contemplation-block compact">
          <view class="edict-label">今日观心</view>
          <view>
            <text wx:for="{{heroView.contemplationLines}}" wx:key="*this">{{item}}</text>
          </view>
        </view>

        <view wx:if="{{threeSeals.completed}}" class="live-mirror-block">
          <view class="live-mirror-head">
            <view>
              <view class="edict-label">真实复盘采集</view>
              <text>活镜提醒</text>
            </view>
            <text>{{liveMirrorReminder.statusText}}</text>
          </view>
          <view class="live-mirror-line">{{liveMirrorReminder.reminderLine}}</view>
          <view class="live-mirror-grid">
            <view>
              <text>高频心贼</text>
              <view>{{liveMirrorReminder.highFrequencyThievesText}}</view>
              <text>{{liveMirrorReminder.highFrequencyThievesDetail}}</text>
            </view>
            <view>
              <text>高频阶段</text>
              <view>{{liveMirrorReminder.highFrequencyStage}}</view>
              <text>{{liveMirrorReminder.stageDetail}}</text>
            </view>
            <view>
              <text>主修训练</text>
              <view>{{liveMirrorReminder.focusMirror}}</view>
              <text>{{liveMirrorReminder.mainTraining}}</text>
            </view>
          </view>
          <view wx:if="{{liveMirrorReminder.latest}}" class="live-mirror-latest">
            <text>最近记录</text>
            <view>{{liveMirrorReminder.latest.marketLine}}</view>
            <text>{{liveMirrorReminder.latest.stageLine}}</text>
          </view>
          <view class="live-mirror-actions">
            <button data-noripple="1" bindtap="goTradeReview">{{liveMirrorReminder.primaryActionText}}</button>
            <button data-noripple="1" bindtap="goTradeReviewArchive">{{liveMirrorReminder.archiveActionText}}</button>
          </view>
        </view>

        <view class="today-stage-block">
          <view class="edict-label">今日阶段</view>
          <button
            wx:for="{{todayStages}}"
            wx:key="key"
            data-route="{{item.route}}"
            data-noripple="1"
            class="today-stage-row {{item.done ? 'done' : ''}}"
            bindtap="goTodayStage"
          >
            <view>{{item.title}}</view>
            <text>{{item.status}}</text>
          </button>
        </view>

        <view class="today-three">
          <view class="edict-label">今日任务清单</view>
          <button
            wx:for="{{heroTasks.list}}"
            wx:key="key"
            data-key="{{item.key}}"
            data-noripple="1"
            class="today-three-row {{item.done ? 'done' : ''}}"
            bindtap="handleHeroTask"
          >
            <text>{{index + 1}}</text>
            <view>{{item.title}}</view>
            <text>{{item.status}}</text>
          </button>
          <button data-noripple="1" class="today-checkin-button" bindtap="completeTodayCheckIn">完成今日打卡</button>
        </view>

        <view class="hero-bottom-actions">
          <button data-noripple="1" bindtap="goReportBridge">查看我的人格报告</button>
          <button data-noripple="1" bindtap="goTrainingDay">{{heroTasks.trainingButtonText}}</button>
        </view>
        <view class="hero-secondary-actions">
          <button data-noripple="1" bindtap="goZhixingIndex">知行指数</button>
          <button data-noripple="1" bindtap="goClassroom">知行讲堂</button>
        </view>
        <view class="hero-share-actions">
          <button data-noripple="1" data-type="daily_mantra" bindtap="goShareCard">生成今日心证卡</button>
          <button data-noripple="1" data-type="companion_invite" bindtap="goShareCard">邀一位同修同行</button>
        </view>
        <view data-noripple="1" class="edict-footnote" bindtap="openPosterMode">长按收藏 / 记录今日心证</view>
      </view>
    </view>

    <view class="scene scene-reaction-detail">
      <view class="reaction-recorder">
        <view class="reaction-head">
          <view>
            <text>交易反应记录</text>
            <view>{{reactionRecord ? '今日已记录，可继续补充。' : '今天交易中最强烈的一个反应是什么？'}}</view>
          </view>
          <text>{{reactionRecord ? '已打卡' : '待打卡'}}</text>
        </view>
        <view class="reaction-question">是恐惧、贪念、证明、后悔、急躁，还是逃避？当时有没有偏离计划？</view>
        <view class="reaction-tags">
          <button
            wx:for="{{reactionTags}}"
            wx:key="*this"
            data-tag="{{item}}"
            data-noripple="1"
            class="{{selectedReactionTag === item ? 'active' : ''}}"
            bindtap="selectReactionTag"
          >{{item}}</button>
        </view>
        <textarea
          class="reaction-input"
          maxlength="80"
          value="{{reactionDraft}}"
          placeholder="例：边界快到时，我开始想找理由；这一次先停了十秒，没有跟着念头走。"
          placeholder-class="reaction-placeholder"
          bindinput="inputReaction"
        />
        <button data-noripple="1" class="reaction-save" bindtap="saveReactionRecord">{{reactionRecord ? '更新今日行为打卡' : '记录今日行为打卡'}}</button>
      </view>
    </view>

    <view class="scene scene-retention">
      <view class="retention-card seven-day-card">
        <view class="retention-head">
          <view>
            <text>{{training7Summary.title}}</text>
            <view>{{training7Summary.currentText}} · {{training7Summary.todayTitle}}</view>
          </view>
          <text>{{training7Summary.statusText}}</text>
        </view>
        <view class="retention-bar"><view style="width: {{training7Summary.progress}}%;"></view></view>
        <view class="seven-day-strip">
          <view wx:for="{{training7View.days}}" wx:key="day" class="seven-day-dot {{item.completed ? 'done' : ''}} {{item.active ? 'active' : ''}}">
            <text>{{item.day}}</text>
            <view>{{item.title}}</view>
          </view>
        </view>
        <button data-noripple="1" class="retention-next" bindtap="goRetest">
          <text class="retention-next-label">复测变化</text>
          <view class="retention-next-detail">{{training7Summary.retestText}}</view>
        </button>
      </view>

      <view class="retention-card">
        <view class="retention-head">
          <view>
            <text>今日训练进度</text>
            <view>{{retentionView.dailyHook}}</view>
          </view>
          <text>{{retentionView.loop.statusText}}</text>
        </view>
        <view class="retention-bar"><view style="width: {{retentionView.loop.progress}}%;"></view></view>
        <view class="loop-step-strip">
          <button
            wx:for="{{loopSteps}}"
            wx:key="key"
            data-index="{{index}}"
            data-noripple="1"
            class="loop-step {{item.done ? 'done' : ''}} {{item.active ? 'active' : ''}}"
            bindtap="goLoopStep"
          >
            <text>{{item.shortName}}</text>
            <view>{{item.status}}</view>
          </button>
        </view>
        <button data-noripple="1" class="retention-next" bindtap="goNextStep">
          <text class="retention-next-label">下一步</text>
          <view class="retention-next-detail">{{retentionView.loop.nextName}} · {{retentionView.loop.nextAction}}</view>
        </button>
      </view>

      <view class="retention-grid">
        <view data-noripple="1" class="retention-mini" bindtap="goContent365">
          <text>全年修行</text>
          <view>{{retentionView.content365.subtitle}}</view>
          <view class="mini-progress"><view style="width: {{retentionView.content365.progress}}%;"></view></view>
          <text>{{retentionView.content365.nextText}}</text>
        </view>
        <view data-noripple="1" class="retention-mini" bindtap="goProfile">
          <text>长期训练</text>
          <view>{{retentionView.longTraining.title}}</view>
          <view class="mini-progress"><view style="width: {{retentionView.longTraining.progress}}%;"></view></view>
          <text>{{retentionView.longTraining.subtitle}}</text>
        </view>
      </view>

      <view data-noripple="1" class="retest-banner {{retentionView.retest.due ? 'due' : ''}}" bindtap="goRetest">
        <view>
          <text>{{retentionView.retest.label}}</text>
          <view>{{retentionView.retest.hint}}</view>
        </view>
        <text>{{retentionView.retest.actionText}}</text>
      </view>
    </view>

    <view class="scene scene-oath {{ritualProgress.ready ? 'ready' : ''}}">
      <view class="scene-ordinal">第二幕 · 立誓</view>
      <view class="vow-head">
        <view>
          <view class="section-label">今日戒律</view>
          <view class="commandment-text">{{dailyContent.commandment}}</view>
        </view>
        <text>{{ritualProgress.statusText}}</text>
      </view>
      <view class="vow-hint">{{ritualProgress.hint}}</view>
      <view class="vow-list">
        <button
          wx:for="{{vows}}"
          wx:key="key"
          data-key="{{item.key}}"
          data-noripple="1"
          class="vow-row {{item.checked ? 'checked' : ''}} {{sealEffectKey === item.key ? 'sealing' : ''}}"
          bindtap="toggleVow"
        >
          <view class="seal-imprint"></view>
          <view class="seal-mark">
            <text>{{item.seal}}</text>
          </view>
          <view wx:if="{{sealEffectKey === item.key}}" class="falling-seal">{{item.seal}}印</view>
          <view class="vow-copy">
            <text>{{item.text}}</text>
            <view>{{item.statusText}}</view>
          </view>
        </button>
      </view>
    </view>

    <view class="scene scene-practice {{ritualProgress.ready ? 'ready' : ''}} {{homeRitualState.cardDone ? 'card-done' : ''}}">
      <view class="scene-ordinal">第三幕 · 入事</view>
      <view class="primary-task-label">{{primaryTaskLabel}}</view>
      <view class="primary-task-text">{{primaryTaskText}}</view>
      <button data-noripple="1" class="ritual-primary" bindtap="handleTodayAction">{{buttonText}}</button>
      <view class="local-note">{{ritualProgress.localNote}}</view>
      <view data-noripple="1" class="heart-card-teaser {{ritualProgress.ready ? 'ready' : ''}} {{homeRitualState.cardDone ? 'done' : ''}}" bindtap="previewHeartCard">
        <view class="teaser-copy">
          <view class="teaser-kicker">{{ritualProgress.cardKicker}}</view>
          <view class="teaser-title">{{ritualProgress.cardTitle}}</view>
          <text>{{ritualProgress.cardCopy}}</text>
        </view>
        <view class="mini-heart-card">
          <view class="mini-card-line"></view>
          <text class="mini-card-day">{{shareCard.dayId}}</text>
          <view class="mini-card-proof">{{shareCard.heartProof}}</view>
          <view class="mini-card-meta">{{shareCard.rankName}} · {{shareCard.streakText}}</view>
          <view class="mini-card-seal">{{shareCard.stageSeal.seal}}</view>
          <view class="mini-card-qr">
            <view
              wx:for="{{qrBlocks}}"
              wx:key="key"
              class="{{item.active ? 'active' : ''}}"
            ></view>
          </view>
        </view>
      </view>
    </view>

    <view class="scene scene-companion {{homeRitualState.completed ? 'closed' : ''}}">
      <view class="scene-ordinal">第四幕 · 归卷</view>
      <view class="section-label">同行</view>
      <view class="companion-title">{{companionView.unityLine}}</view>
      <view class="companion-note">{{companionView.whisper}}</view>
      <view class="companion-quiet-card">
        <view class="lamp-field">
          <view
            wx:for="{{companionView.lamps}}"
            wx:key="key"
            class="lamp-dot {{item.active ? 'active' : ''}}"
          ></view>
        </view>
        <view class="companion-metrics">
          <view>
            <text>{{companionView.stageMates}}</text>
            <view>同修{{companionView.stageShort}}</view>
          </view>
          <view>
            <text>{{companionView.oathMates}}</text>
            <view>同守一戒</view>
          </view>
        </view>
      </view>
    </view>

    <view class="entry-panel sync-entry-panel">
      <label class="phone-field">
        <text>手机号 · 贯穿报告、训练、复测与助教</text>
        <input
          data-noripple="1"
          type="number"
          maxlength="11"
          value="{{phone}}"
          placeholder="用于同步修行记录"
          placeholder-class="input-placeholder"
          bindinput="inputPhone"
        />
      </label>
      <view class="entry-note">数据仅用于本页状态记录</view>
    </view>

    <compliance-notice compact="{{true}}" />
  </view>

  <view wx:if="{{posterMode}}" class="edict-poster-mode" catchtap="closePosterMode" catchtouchmove="noop">
    <view class="poster-bg poster-glow"></view>
    <view class="poster-bg poster-mountain"></view>
    <view class="poster-bg poster-grain"></view>

    <view class="poster-header">
      <view class="poster-seal">知</view>
      <view>
        <view class="poster-brand">阳明心学交易系统</view>
        <view class="poster-subtitle">每日一页 · 照见本心</view>
      </view>
    </view>

    <view class="poster-edict">
      <view class="poster-line"></view>
      <view class="poster-kicker">
        <text>{{heroView.dayLabel}}</text>
        <text>{{heroView.todayStageLabel}}</text>
      </view>
      <view class="poster-label">今日心证</view>
      <view class="poster-proof">
        <text wx:for="{{heroView.heartProofLines}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="poster-line bottom"></view>
    </view>

    <view class="poster-footer">
      <view class="poster-footer-seal">{{shareCard.stageSeal.seal}}</view>
      <view>
        <view>不做行情判断，不提供操作指令。</view>
        <view>只训练知行合一。</view>
      </view>
    </view>
  </view>

  <view wx:if="{{cardGenerating}}" class="quiet-loading" catchtap="noop" catchtouchmove="noop">
    <view class="quiet-loading-card">
      <view class="quiet-loading-seal">证</view>
      <text>正在落成心证卡</text>
      <view>正在把今日照见写入证据账本，请稍候。</view>
    </view>
  </view>

  <canvas type="2d" id="heartCardCanvas" class="heart-card-canvas"></canvas>

  <bottom-tab-bar wx:if="{{!posterMode}}" active="today" />
</view>
