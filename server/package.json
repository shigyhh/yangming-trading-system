{
  "name": "trading-personality-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "generate:questions": "node scripts/generate-question-bank.mjs",
    "import:questions": "node scripts/import-question-bank.mjs",
    "generate:kline": "node scripts/generate-kline-bank.mjs",
    "cache:ashare": "node scripts/cache-ashare-market-data.mjs",
    "cache:akshare": "python3 scripts/sync-akshare-offline.py",
    "download:kline": "node scripts/download-kline-history.mjs",
    "kline:update": "node scripts/update-kline-cache.js",
    "kline:verify": "node scripts/verify-kline-cache.js",
    "kline:benchmark": "node scripts/benchmark-kline-providers.js",
    "kline:backfill": "node scripts/backfill-kline-cache.js",
    "update:ashare": "node scripts/cache-ashare-market-data.mjs --limit all --timeframes 101 --delay 300 --incremental --summary-only",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:data-binding": "node --test scripts/data-binding-contract-test.mjs",
    "test:global-reflection": "node --test scripts/global-reflection-test.mjs",
    "test:i18n": "node --test scripts/i18n-contract-test.mjs",
    "test:kline-history": "node --test scripts/historical-kline-contract-test.mjs",
    "check": "node --check src/index.js"
  },
  "engines": {
    "node": ">=18"
  }
}
